# YouthCamping Local Development Environment Variables Template
PORT=3001
NODE_ENV=development

# Database Connections (Explicitly Local Hostname Allowlist Check)
DATABASE_URL=postgresql://postgres:local_password@127.0.0.1:5432/youthcamping_test
DIRECT_URL=postgresql://postgres:local_password@127.0.0.1:5432/youthcamping_test

# Auth and Security
JWT_SECRET=local_development_jwt_secret_min_32_characters_long
JWT_EXPIRES_IN=7d

# Remote database access is denied unless production explicitly opts in.
# Keep false for every local/development/test environment. Set true only in
# the secured VPS process environment, never in a committed or local env file.
ALLOW_PRODUCTION_DATABASE=false

# Mutating tests are disabled by default and require an isolated test database.
ALLOW_MUTATING_TESTS=false
TEST_API_URL=http://127.0.0.1:3001/api
TEST_ADMIN_EMAIL=
TEST_ADMIN_PASSWORD=
TEST_SECONDARY_ADMIN_EMAIL=
TEST_SECONDARY_ADMIN_PASSWORD=
TEST_BOOKING_LINK_TOKEN=

# Client / Frontend Paths
FRONTEND_URL=http://localhost:3000
CLIENT_URL=http://localhost:3000
ADMIN_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Email Services
BREVO_API_KEY=xkeysib-local_development_brevo_placeholder
EMAIL_FROM=local-dev@youthcamping.online
# Optional: comma-separated internal BCC recipients for all outgoing emails
# INTERNAL_EMAIL_BCC=internal@example.com,backup@example.com

# Cloudinary Storage
CLOUDINARY_CLOUD_NAME=local_cloudinary_cloud_name
CLOUDINARY_API_KEY=local_cloudinary_api_key
CLOUDINARY_API_SECRET=local_cloudinary_api_secret

# Google Apps Script integration
GOOGLE_APPS_SCRIPT_URL=https://script.google.com/macros/s/local_development_apps_script_url/exec
DISABLE_RATE_LIMIT=true
