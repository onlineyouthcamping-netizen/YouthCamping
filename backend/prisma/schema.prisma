model BookingActivityLog {
  id                  String   @id @default(cuid())
  bookingId           String
  action              String
  details             String   @db.Text
  performedByAdminId  String?
  createdAt           DateTime @default(now())

  booking             Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  performedBy         Admin?   @relation("BookingActivityActor", fields: [performedByAdminId], references: [id], onDelete: SetNull)

  @@index([bookingId])
  @@index([createdAt])
}

model BookingTask {
  id              String   @id @default(cuid())
  tenantId        String   @default("default")
  bookingId       String
  title           String
  description     String   @db.Text
  status          String   @default("PENDING") // PENDING, IN_PROGRESS, COMPLETED
  dueDate         DateTime?
  assignedById    String
  assignedToId    String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  booking         Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  assignedBy      Admin    @relation("TaskAssignedBy", fields: [assignedById], references: [id])
  assignedTo      Admin    @relation("TaskAssignedTo", fields: [assignedToId], references: [id])

  @@index([bookingId])
  @@index([assignedById])
  @@index([assignedToId])
}

model UserNavState {
  id             String   @id @default(cuid())
  userId         String   @unique
  expandedModule String
  updatedAt      DateTime @updatedAt
}

model KnowledgeSection {
  id          String   @id @default(cuid())
  tripId      String
  tabKey      String
  title       String
  description String   @db.Text
  itemCount   Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tripId])
  @@index([tabKey])
}

model TripNotice {
  id        String   @id @default(cuid())
  tripId    String
  title     String
  body      String   @db.Text
  createdAt DateTime @default(now())

  @@index([tripId])
}

model EmailTemplate {
  id                String   @id @default(cuid())
  tenantId          String   @default("default")
  name              String
  subject           String
  body              String   @db.Text
  category          String   // e.g. "Booking", "Inquiry", "Ticketing", "General"
  isActive          Boolean  @default(true)
  defaultAttachments Json?   // Array of files
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([category])
}

model EmailLog {
  id              String   @id @default(cuid())
  tenantId        String   @default("default")
  
  bookingId       String?
  booking         Booking? @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  
  inquiryId       String?
  inquiry         Inquiry? @relation(fields: [inquiryId], references: [id], onDelete: Cascade)
  
  trainTicketId   String?
  trainTicket     TrainTicket? @relation(fields: [trainTicketId], references: [id], onDelete: Cascade)

  senderId        String?
  sender          Admin?   @relation(fields: [senderId], references: [id], onDelete: SetNull)
  
  recipient       String
  ccCount         Int      @default(0)
  bccCount        Int      @default(0)
  subject         String
  body            String   @db.Text
  templateId      String?
  templateName    String?
  attachments     Json?    // Array of file metadata
  status          String   @default("PENDING") // SENT, FAILED
  error           String?  // Failure reason
  isTest          Boolean  @default(false)
  sentAt          DateTime @default(now())

  @@index([bookingId])
  @@index([inquiryId])
  @@index([trainTicketId])
  @@index([senderId])
}

// ==========================================
// PACKAGE BUILDER MODULE
// ==========================================

// ── State / Region ──
model PackageState {
  id        String          @id @default(cuid())
  tenantId  String          @default("default")
  name      String          @unique
  isActive  Boolean         @default(true)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  cities    PackageCity[]

  @@index([tenantId])
}

// ── Destination / City ──
model PackageCity {
  id        String          @id @default(cuid())
  tenantId  String          @default("default")
  stateId   String
  name      String
  isActive  Boolean         @default(true)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  state     PackageState    @relation(fields: [stateId], references: [id], onDelete: Cascade)
  hotels    PackageHotel[]
  vehicles  PackageVehicle[]
  activities PackageActivity[]
  transferFrom PackageTransferRoute[] @relation("TransferFromCity")
  transferTo   PackageTransferRoute[] @relation("TransferToCity")
  itineraryDays PackageItineraryDay[]

  @@unique([tenantId, stateId, name])
  @@index([tenantId])
  @@index([stateId])
}

// ── Vendor (Package-specific) ──
model PackageVendor {
  id            String        @id @default(cuid())
  tenantId      String        @default("default")
  name          String
  type          String        // HOTEL | VEHICLE | ACTIVITY | MEALS | GUIDE | OTHER
  contactPerson String?
  email         String?
  phone         String?
  location      String?
  gstNumber     String?
  isActive      Boolean       @default(true)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  hotels        PackageHotel[]
  vehicles      PackageVehicle[]
  activities    PackageActivity[]
  meals         PackageMealPlan[]

  @@index([tenantId])
  @@index([type])
}

// ── Hotel / Resort ──
model PackageHotel {
  id            String              @id @default(cuid())
  tenantId      String              @default("default")
  cityId        String
  name          String
  category      String              // Budget | Standard | Deluxe | Premium | Luxury
  roomType      String              // Standard | Deluxe | Super Deluxe | Premium | Suite
  maxPeoplePerRoom Int              @default(2)
  mealPlan      String              // EP | CP | MAP | AP
  basePrice     Float               @default(0)
  weekendPrice  Float?
  peakSeasonPrice Float?
  extraMattressPrice Float?         @default(0)
  extraAdultPrice Float?            @default(0)
  childWithBedPrice Float?          @default(0)
  childWithoutBedPrice Float?       @default(0)
  images        String[]            @default([])
  vendorId      String?
  contactName   String?
  contactPhone  String?
  isActive      Boolean             @default(true)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  city          PackageCity         @relation(fields: [cityId], references: [id], onDelete: Cascade)
  vendor        PackageVendor?      @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  tariffs       PackageHotelTariff[]

  @@index([tenantId])
  @@index([cityId])
  @@index([category])
}

// ── Seasonal Hotel Tariff ──
model PackageHotelTariff {
  id        String   @id @default(cuid())
  hotelId   String
  startDate DateTime @db.Date
  endDate   DateTime @db.Date
  roomRate  Float    @default(0)
  label     String?  // "Peak Season", "Weekend", "Diwali", etc.

  hotel     PackageHotel @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@index([hotelId])
  @@index([startDate, endDate])
}

// ── Vehicle / Transportation ──
model PackageVehicle {
  id            String             @id @default(cuid())
  tenantId      String             @default("default")
  cityId        String
  name          String             // Ertiga, Innova, Crysta, Tempo Traveller, Bus, Volvo
  seatingCapacity Int
  isAc          Boolean            @default(true)
  image         String?
  vendorId      String?
  isActive      Boolean            @default(true)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  city          PackageCity        @relation(fields: [cityId], references: [id], onDelete: Cascade)
  vendor        PackageVendor?     @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  tariffs       PackageVehicleTariff[]

  @@index([tenantId])
  @@index([cityId])
}

// ── Vehicle Pricing ──
model PackageVehicleTariff {
  id            String          @id @default(cuid())
  vehicleId     String
  priceType     String          // PER_DAY | PER_KM | FIXED_ROUTE | AIRPORT | RAILWAY
  perDayRate    Float?
  perKmRate     Float?
  fixedRouteRate Float?
  minKmPerDay   Int?            @default(0)
  driverAllowance Float?        @default(0)
  fuelIncluded  Boolean         @default(true)
  tollParkingIncluded Boolean   @default(false)
  notes         String?

  vehicle       PackageVehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId])
}

// ── Transfer Route ──
model PackageTransferRoute {
  id              String        @id @default(cuid())
  tenantId        String        @default("default")
  fromCityId      String
  toCityId        String
  distanceKm      Float?
  travelTimeMins  Int?
  suggestedVehicle String?
  fixedRate       Float?
  perKmRate       Float?
  pickupDropNotes String?
  isActive        Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  fromCity        PackageCity   @relation("TransferFromCity", fields: [fromCityId], references: [id], onDelete: Cascade)
  toCity          PackageCity   @relation("TransferToCity", fields: [toCityId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([fromCityId])
  @@index([toCityId])
}

// ── Activity / Sightseeing ──
model PackageActivity {
  id            String               @id @default(cuid())
  tenantId      String               @default("default")
  cityId        String
  name          String
  adultRate     Float                @default(0)
  childRate     Float                @default(0)
  isShared      Boolean              @default(true)
  duration      String?              // "2 hrs", "Half Day", "Full Day"
  description   String?
  includedItems String?              @db.Text
  excludedItems String?              @db.Text
  image         String?
  vendorId      String?
  isActive      Boolean              @default(true)
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  city          PackageCity          @relation(fields: [cityId], references: [id], onDelete: Cascade)
  vendor        PackageVendor?       @relation(fields: [vendorId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([cityId])
}

// ── Meal Plan ──
model PackageMealPlan {
  id            String         @id @default(cuid())
  tenantId      String         @default("default")
  vendorId      String?
  name          String         // "EP", "CP", "MAP", "AP" or custom
  breakfastCost Float?         @default(0)
  lunchCost     Float?         @default(0)
  dinnerCost    Float?         @default(0)
  perPersonPerDay Float?       @default(0)
  description   String?
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  vendor        PackageVendor? @relation(fields: [vendorId], references: [id], onDelete: SetNull)

  @@index([tenantId])
}

// ── Package Draft / Quote ──
model PackageDraft {
  id              String                @id @default(cuid())
  tenantId        String                @default("default")
  draftId         String                @unique
  status          String                @default("draft") // draft | template | quoted | converted

  // Customer
  customerName    String?
  customerPhone   String?
  customerEmail   String?
  customerAddress String?

  // Package details
  packageName     String?
  stateId         String?
  departureCity   String?
  travelStartDate DateTime?             @db.Date
  travelEndDate   DateTime?             @db.Date
  totalNights     Int                   @default(0)
  totalDays       Int                   @default(0)
  adults          Int                   @default(0)
  children        Int                   @default(0)
  couples         Int                   @default(0)
  totalRooms      Int                   @default(0)
  roomConfig      Json?                 // room allocation details
  specialNotes    String?               @db.Text
  inclusions      String?               @db.Text
  exclusions      String?               @db.Text
  terms           String?               @db.Text

  // Pricing (recalculated server-side)
  hotelCost       Float                 @default(0)
  vehicleCost     Float                 @default(0)
  transferCost    Float                 @default(0)
  activityCost    Float                 @default(0)
  mealCost        Float                 @default(0)
  guideCost       Float                 @default(0)
  trainCost       Float                 @default(0)
  flightCost      Float                 @default(0)
  miscCost        Float                 @default(0)
  subtotal        Float                 @default(0)
  discount        Float                 @default(0)
  discountType    String?               // percentage | fixed
  gstRate         Float                 @default(5)
  gstAmount       Float                 @default(0)
  serviceCharge   Float                 @default(0)
  totalAmount     Float                 @default(0)

  // Internal vendor costs (hidden from sales)
  vendorHotelCost   Float               @default(0)
  vendorVehicleCost Float               @default(0)
  vendorActivityCost Float              @default(0)
  vendorMealCost    Float               @default(0)
  vendorGuideCost   Float               @default(0)
  estimatedMargin   Float               @default(0)

  // Quote
  quoteNumber     String?
  quoteValidity   String?               @default("48 hours")
  paymentTerms    String?               @default("50% advance, 50% before travel")
  quoteSentAt     DateTime?

  // Audit
  salesAdminId    String?
  createdById     String?
  updatedById     String?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  // Relations
  salesAdmin      Admin?                @relation("SalesPackageDrafts", fields: [salesAdminId], references: [id], onDelete: SetNull)
  createdBy       Admin?                @relation("PackageDraftCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy       Admin?                @relation("PackageDraftUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  itineraryDays   PackageItineraryDay[]

  @@index([tenantId])
  @@index([status])
  @@index([salesAdminId])
  @@index([tenantId, status, createdAt(sort: Desc)])
}

// ── Itinerary Day ──
model PackageItineraryDay {
  id            String          @id @default(cuid())
  draftId       String
  dayNumber     Int
  date          DateTime?       @db.Date
  stayCityId    String?
  title         String?         // Optional custom title
  routeFrom     String?
  routeTo       String?
  distanceKm    Float?
  travelTimeMins Int?
  notes         String?         @db.Text

  draft         PackageDraft    @relation(fields: [draftId], references: [id], onDelete: Cascade)
  stayCity      PackageCity?    @relation(fields: [stayCityId], references: [id], onDelete: SetNull)
  items         PackageItineraryItem[]

  @@index([draftId])
  @@index([dayNumber])
}

// ── Itinerary Item (service assigned to a day) ──
model PackageItineraryItem {
  id            String   @id @default(cuid())
  dayId         String
  serviceType   String   // HOTEL | VEHICLE | TRANSFER | ACTIVITY | MEAL | GUIDE | TRAIN | FLIGHT | CUSTOM
  serviceId     String?  // ID of the master record (PackageHotel.id, etc.)
  label         String   // Display name
  description   String?  @db.Text
  quantity      Int      @default(1)
  rate          Float    @default(0)
  amount        Float    @default(0)
  isVendorCost  Boolean  @default(false)
  sortOrder     Int      @default(0)
  metadata      Json?    // Extra data (room type, meal plan, vehicle type, etc.)

  day           PackageItineraryDay @relation(fields: [dayId], references: [id], onDelete: Cascade)

  @@index([dayId])
}

// ── Package Activity Log (audit trail) ──
model PackageActivityLog {
  id          String   @id @default(cuid())
  tenantId    String   @default("default")
  draftId     String?
  action      String
  details     String?  @db.Text
  actorId     String?
  beforeData  Json?
  afterData   Json?
  createdAt   DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([draftId])
}

// ==========================================
// TRAVEL DESK MODULE
// ==========================================

// ── TICKETING SOPs ──
model TicketingSop {
  id          String             @id @default(cuid())
  tripId      String
  category    String             // e.g. "train", "flight", "bus", "cancellation"
  title       String
  description String             @db.Text
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  trip        Trip               @relation(fields: [tripId], references: [id], onDelete: Cascade)
  items       TicketingSopItem[]

  @@index([tripId])
  @@index([category])
}

model TicketingSopItem {
  id        String       @id @default(cuid())
  sopId     String
  title     String
  content   String?      @db.Text
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  sop       TicketingSop @relation(fields: [sopId], references: [id], onDelete: Cascade)

  @@index([sopId])
}

// ── TICKETING QUICK LINKS ──
model TicketingLink {
  id        String   @id @default(cuid())
  tripId    String
  label     String
  val       String
  icon      String
  linkUrl   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  trip      Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([tripId])
}

// ── ITINERARY (parent: supports multiple variants) ──
model Itinerary {
  id          String              @id @default(cuid())
  tripId      String
  name        String
  isDefault   Boolean             @default(false)
  version     Int                 @default(1)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  trip        Trip                @relation(fields: [tripId], references: [id], onDelete: Cascade)
  days        ItineraryDay[]
  routeMaps   ItineraryRouteMap[]
  inclusions  ItineraryInclusion[]
  exclusions  ItineraryExclusion[]
  notes       ItineraryNote[]

  @@index([tripId])
}

model ItineraryDay {
  id          String    @id @default(cuid())
  itineraryId String
  dayNumber   String
  dayDate     String
  plan        String    @db.Text
  stay        String
  meals       String
  transport   String
  distance    String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  itinerary   Itinerary @relation(fields: [itineraryId], references: [id], onDelete: Cascade)

  @@index([itineraryId])
}

model ItineraryRouteMap {
  id          String    @id @default(cuid())
  itineraryId String
  mapUrl      String?
  description String?   @db.Text
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  itinerary   Itinerary @relation(fields: [itineraryId], references: [id], onDelete: Cascade)

  @@index([itineraryId])
}

model ItineraryInclusion {
  id          String    @id @default(cuid())
  itineraryId String
  text        String    @db.Text
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  itinerary   Itinerary @relation(fields: [itineraryId], references: [id], onDelete: Cascade)

  @@index([itineraryId])
}

model ItineraryExclusion {
  id          String    @id @default(cuid())
  itineraryId String
  text        String    @db.Text
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  itinerary   Itinerary @relation(fields: [itineraryId], references: [id], onDelete: Cascade)

  @@index([itineraryId])
}

model ItineraryNote {
  id          String    @id @default(cuid())
  itineraryId String
  title       String
  body        String    @db.Text
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  itinerary   Itinerary @relation(fields: [itineraryId], references: [id], onDelete: Cascade)

  @@index([itineraryId])
}

// ── TRIP SOPs (Travel Desk) ──
model TripSop {
  id          String        @id @default(cuid())
  tripId      String
  title       String
  description String        @db.Text
  category    String
  icon        String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  trip        Trip          @relation(fields: [tripId], references: [id], onDelete: Cascade)
  items       TripSopItem[]

  @@index([tripId])
}

model TripSopItem {
  id        String   @id @default(cuid())
  sopId     String
  title     String
  content   String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sop       TripSop  @relation(fields: [sopId], references: [id], onDelete: Cascade)

  @@index([sopId])
}

// ── TRIP DOCUMENTS ──
model TripDocument {
  id        String   @id @default(cuid())
  tripId    String
  name      String
  category  String
  fileType  String
  size      String?
  addedBy   String
  dateAdded DateTime @default(now())
  fileUrl   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  trip      Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([tripId])
}

// ── TRIP GALLERY ──
model TripGallery {
  id        String   @id @default(cuid())
  tripId    String
  title     String
  imageUrl  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  trip      Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([tripId])
}

// ── TRIP NOTES & UPDATES ──
model TripNote {
  id        String   @id @default(cuid())
  tripId    String
  title     String
  content   String?  @db.Text
  category  String
  linkUrl   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  trip      Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([tripId])
  @@index([category])
}

// ── ANNOUNCEMENTS ──
model Announcement {
  id        String   @id @default(cuid())
  tenantId  String   @default("default")
  title     String
  author    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
}
