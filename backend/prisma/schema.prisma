  departureDate   DateTime?
  paxCount        Int

  vendorCost      Decimal  @db.Decimal(12, 2)
  costPerPerson   Decimal  @db.Decimal(12, 2)

  calculationData Json
  vendorRatesData Json

  createdById     String?
  createdAt       DateTime @default(now())

  @@index([tripId, departureDate])
}

model DirectoryVendorContract {
