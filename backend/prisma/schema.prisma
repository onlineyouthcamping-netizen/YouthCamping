  trip          Trip     @relation(fields: [tripId], references: [id], onDelete: Restrict)

  @@index([tripId, departureDate])
}

// ── SEAT MANAGEMENT CONFIG & ALERTS ──
model OpsSeatConfig {
  id             String   @id @default(cuid())
  tenantId       String   @default("default")
  tripId         String
  departureDate  DateTime @db.Date
  totalSeatsCap  Int      @default(30)
  alertThreshold Int      @default(25)
  blockedSeats   Int      @default(0)
  alertSent      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  trip           Trip     @relation(fields: [tripId], references: [id], onDelete: Restrict)

  @@unique([tenantId, tripId, departureDate])
}

// ── TRIP SOP LIBRARY ──
model OpsSOPTemplate {
  id          String      @id @default(cuid())
  tenantId    String      @default("default")
  destination String
  stage       OpsSOPStage
  taskName    String
  description String?     @db.Text
  createdAt   DateTime    @default(now())

  @@index([tenantId, destination])
}

// ── TRIP-WISE CHECKLIST ITEM ──
model OpsTripChecklist {
  id            String      @id @default(cuid())
  tenantId      String      @default("default")
  tripId        String
  departureDate DateTime    @db.Date
  stage         OpsSOPStage
  taskName      String
  isCompleted   Boolean     @default(false)
  completedById String?
  completedAt   DateTime?
  notes         String?

  trip          Trip        @relation(fields: [tripId], references: [id], onDelete: Restrict)
  completedBy   Admin?      @relation("ChecklistCompletedByAdmin", fields: [completedById], references: [id], onDelete: Restrict)
  activities    OpsChecklistActivity[]

  @@index([tripId, departureDate, stage])
}

// ── CHECKLIST ITEM ACTIVITY LOG ──
model OpsChecklistActivity {
  id               String             @id @default(cuid())
  tenantId         String             @default("default")
  checklistItemId  String
  action           OpsChecklistAction
  previousStatus   Boolean
  nextStatus       Boolean
  notes            String?            @db.Text
  actorId          String
  createdAt        DateTime           @default(now())

  checklist        OpsTripChecklist   @relation(fields: [checklistItemId], references: [id], onDelete: Restrict)
  actor            Admin              @relation(fields: [actorId], references: [id], onDelete: Restrict)

  @@index([tenantId])
  @@index([checklistItemId])
}

// ── INCIDENT / ISSUE LOG ──
model OpsIncidentLog {
  id            String            @id @default(cuid())
  tenantId      String            @default("default")
  tripId        String
  departureDate DateTime          @db.Date
  title         String
  severity      IncidentSeverity  @default(MEDIUM)
  description   String            @db.Text
  resolution    String?           @db.Text
  reportedById  String
  incidentType  OpsIncidentType   @default(OTHER)
  status        OpsIncidentStatus @default(OPEN)
  resolvedById  String?
  resolvedAt    DateTime?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  trip          Trip                  @relation(fields: [tripId], references: [id], onDelete: Restrict)
  reportedBy    Admin                 @relation("IncidentReportedByAdmin", fields: [reportedById], references: [id], onDelete: Restrict)
  resolvedBy    Admin?                @relation("IncidentResolvedByAdmin", fields: [resolvedById], references: [id], onDelete: Restrict)
  activities    OpsIncidentActivity[]

  @@index([tripId, departureDate])
}

// ── INCIDENT ACTIVITY LOG ──
model OpsIncidentActivity {
  id           String                    @id @default(cuid())
  tenantId     String                    @default("default")
  incidentId   String
  action       OpsIncidentActivityAction
  notes        String?                   @db.Text
  actorId      String
  createdAt    DateTime                  @default(now())

  incident     OpsIncidentLog            @relation(fields: [incidentId], references: [id], onDelete: Restrict)
  actor        Admin                     @relation(fields: [actorId], references: [id], onDelete: Restrict)

  @@index([tenantId])
  @@index([incidentId])
}

// ── AUTO ALLOCATION RUN & OVERRIDE MODELS ──
model OpsAllocationRun {
