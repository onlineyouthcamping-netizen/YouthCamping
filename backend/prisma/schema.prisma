generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Admin {
  id           String    @id @default(cuid())
  email        String    @unique
  password     String
  name         String?
  role         AdminRole @default(admin)
  isActive     Boolean   @default(true)
  tokenVersion Int       @default(0)
  lastLoginAt  DateTime?
  tenantId     String?   @default("default")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // Booking-link ownership (used for sales filtering + analytics)
  createdBookingLinks BookingLink[]    @relation("CreatedBookingLinks")
  salesBookings       Booking[]        @relation("SalesBookings")
  salesInquiries      Inquiry[]        @relation("SalesInquiries")
  salesQuotations     Quotation[]      @relation("SalesQuotations")
  tripAssignments     TripAssignment[]
  sentEmails          EmailLog[]

  // Verification & ticket relations
  verifiedBookings    BookingVerification[]    @relation("VerifiedByAdmin")
  verificationLogs    BookingVerificationLog[] @relation("VerificationLogAdmin")
  trainTicketLogs     TrainTicketLog[]         @relation("TicketLogAdmin")
  ticketHistories     TrainTicketHistory[]     @relation("TicketHistoryAdmin")
  submittedTickets    TrainTicket[]            @relation("TicketSubmittedByAdmin")
  approvalActors      TrainTicketApproval[]    @relation("ApprovalActorAdmin")
  trainTicketGroups   TrainTicketGroup[]       @relation("GroupCreatedByAdmin")
  bookingActivityLogs BookingActivityLog[]     @relation("BookingActivityActor")
  assignedTasks       BookingTask[]            @relation("TaskAssignedBy")
  receivedTasks       BookingTask[]            @relation("TaskAssignedTo")

  // Package Builder relations
  salesPackageDrafts   PackageDraft[] @relation("SalesPackageDrafts")
  createdPackageDrafts PackageDraft[] @relation("PackageDraftCreatedBy")
  updatedPackageDrafts PackageDraft[] @relation("PackageDraftUpdatedBy")

  // Accounting relations
  salesAccountingEntries    AccountingEntry[]    @relation("SalesAccountingEntries")
  actionedAccountingEntries AccountingEntry[]    @relation("ActionedAccountingEntries")
  accountingLogs            AccountingEntryLog[]

  // Ops relations
  opsChecklistsCompleted OpsTripChecklist[]      @relation("ChecklistCompletedByAdmin")
  opsIncidentsReported   OpsIncidentLog[]        @relation("IncidentReportedByAdmin")
  guideOpsPayments       OpsGuidePayment[]       @relation("GuideAssignments")
  approvedOpsPayments    OpsGuidePayment[]       @relation("GuidePaymentApprovals")
  opsAllocationRuns      OpsAllocationRun[]
  opsAllocationOverrides OpsAllocationOverride[]

  // Ops SOP Library Relations
  createdSops  OpsSopLibrary[] @relation("SopCreatedByAdmin")
  updatedSops  OpsSopLibrary[] @relation("SopUpdatedByAdmin")
  archivedSops OpsSopLibrary[] @relation("SopArchivedByAdmin")

  // Ops Trip Leader Relations
  assignedLeaders OpsTripLeader[] @relation("LeaderAssignedByAdmin")
  updatedLeaders  OpsTripLeader[] @relation("LeaderUpdatedByAdmin")
  archivedLeaders OpsTripLeader[] @relation("LeaderArchivedByAdmin")

  // Checklist Activity Relations
  checklistActivities OpsChecklistActivity[]

  // Incident Log Relations
  resolvedIncidents  OpsIncidentLog[]        @relation("IncidentResolvedByAdmin")
  incidentActivities OpsIncidentActivity[]
  leaderActivities   OpsTripLeaderActivity[]

  // Ticket Approval relations
  requestedTicketApprovals TicketApproval[] @relation("TicketApprovalRequestedBy")
  reviewedTicketApprovals  TicketApproval[] @relation("TicketApprovalReviewedBy")
  opsActivities            OpsActivity[]    @relation("OpsActivityGuide")
  opsDocuments             OpsDocument[]    @relation("OpsDocUploadedByAdmin")

  @@index([tenantId])
}

model User {
  id        String   @id @default(cuid())
  tenantId  String   @default("default")
  name      String
  email     String   @unique
  password  String
  phone     String?
  role      String   @default("user")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
}

model Inquiry {
  id           String     @id @default(cuid())
  tenantId     String     @default("default")
  name         String?
  email        String?
  phone        String
  message      String?
  tripId       String?
  tripTitle    String?
  date         String?
  count        Int?
  source       String?
  status       String     @default("new")
  adminNotes   String?
  salesAdminId String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  salesAdmin   Admin?     @relation("SalesInquiries", fields: [salesAdminId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  emailLogs    EmailLog[]

  @@index([tenantId])
  @@index([status])
}

model Vendor {
  id          String       @id @default(cuid())
  tenantId    String       @default("default")
  name        String
  type        String
  email       String?
  phone       String?
  location    String?
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  assignments TripVendor[]

  @@index([tenantId])
}

model TripVendor {
  id                  String   @id @default(cuid())
  tenantId            String   @default("default")
  tripId              String
  vendorId            String
  agreedCost          Float
  paidAmount          Float    @default(0)
  paymentStatus       String   @default("pending")
  notes               String?
  outgoingPaymentMode String?
  onlinePersonAccount String?
  cashDepositorName   String?
  depositAccountName  String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  trip                Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  vendor              Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([tenantId])
  @@index([tripId])
}

model Blog {
  id          String   @id @default(cuid())
  tenantId    String   @default("default")
  title       String
  slug        String   @unique
  content     String
  image       String?
  author      String?  @default("Expedition Team")
  authorImage String?
  status      String   @default("draft")
  readTime    String?  @default("5 MIN READ")
  hasVideo    Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId])
}

model Review {
  id         String   @id @default(cuid())
  tenantId   String   @default("default")
  userName   String
  userHandle String?
  instagram  String?
  city       String?
  tripName   String?
  tripType   String?
  userImage  String?
  comment    String
  rating     Int      @default(5)
  isFeatured Boolean  @default(true)
  photos     String[] @default([])
  tripId     String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([tenantId])
}

model Payment {
  id            String   @id @default(cuid())
  tenantId      String   @default("default")
  bookingId     String
  amount        Float
  status        String   @default("pending")
  transactionId String?
  paymentMode   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([tenantId])
}

model Quotation {
  id           String   @id @default(cuid())
  tenantId     String   @default("default")
  title        String
  slug         String?  @unique
  clientName   String
  totalAmount  Float
  status       String   @default("draft")
  data         Json?
  salesAdminId String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  salesAdmin   Admin?   @relation("SalesQuotations", fields: [salesAdminId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([tenantId])
}

model Trip {
  id             String   @id @default(cuid())
  tenantId       String   @default("default")
  title          String
  shortName      String?
  slug           String   @unique
  location       String
  price          Float
  duration       String
  description    String
  category       String   @default("himalayan")
  isActive       Boolean  @default(true)
  status         String   @default("published")
  heroImage      String?
  images         String[]
  itinerary      Json?
  availableDates Json?
  variants       Json?
  travelOptions  Json?
  roomOptions    Json?
  seo            Json?
  highlights     Json?
  inclusions     Json?
  exclusions     Json?
  faqs           Json?
  addons         Json?
  maxGroupSize   Int?
  difficulty     String?
  departureCity  String?
  pickupCities   Json?

  ageLimit          String?
  bookingUrl        String?
  customSections    Json?
  attractions       Json?
  activities        Json?
  accommodations    Json?
  popupDetails      Json?
  route             Json?
  ageGroup          String?
  maxAltitude       String?
  tripType          String?
  startEnd          String?
  pickupMode        String?
  stickyCardPrice   Float?
  stickyCardLabel   String?
  gstPercentage     Float?  @default(5)
  reels             Json?
  tripReviews       Json?
  itineraryVersions Json?

  order            Int              @default(999)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  bookings         Booking[]
  assignments      TripVendor[]
  opsTripVendors   OpsTripVendor[]
  guideAssignments TripAssignment[]
  trainTemplates   TrainTemplate[]

  // Ops relations
  opsHotelBookings      OpsHotelBooking[]
  opsTransportFleets    OpsTransportFleet[]
  opsGuidePayments      OpsGuidePayment[]
  opsMiscExpenses       OpsMiscExpense[]
  opsSeatConfigs        OpsSeatConfig[]
  opsChecklists         OpsTripChecklist[]
  opsIncidents          OpsIncidentLog[]
  opsRoomAllocations    OpsRoomAllocation[]
  opsVehicleAllocations OpsVehicleAllocation[]
  opsDayItineraries     OpsDayItinerary[]
  opsTripExpenses       OpsTripExpense[]
  opsActivities         OpsActivity[]
  opsVendorPayments     OpsVendorPayment[]
  opsAllocationRuns     OpsAllocationRun[]
  opsRoomInventories    OpsRoomInventory[]
  opsTripLeaders        OpsTripLeader[]

  // Travel Desk relations
  ticketingSops  TicketingSop[]
  ticketingLinks TicketingLink[]
  itineraries    Itinerary[]
  tripSops       TripSop[]
  tripDocuments  TripDocument[]
  tripGalleries  TripGallery[]
  tripNotes      TripNote[]
  opsDocuments   OpsDocument[]
  opsMessages    OpsMessage[]
  knowledgeItems KnowledgeItem[]
  travelQuestions TravelQuestion[]

  @@index([tenantId])
  @@index([category])
  @@index([status])
  @@index([order])
}

model Booking {
  id                  String            @id @default(cuid())
  tenantId            String            @default("default")
  bookingId           String            @unique
  tripId              String
  tripName            String?
  status              String            @default("pending")
  name                String
  fullName            String?
  phone               String
  mobile              String?
  email               String?
  age                 Int?
  gender              String?
  numberOfTravelers   Int?
  baseAmount          Float?
  gstAmount           Float?
  depositGst          Float?
  totalAmount         Float             @default(0)
  amount              Float
  advancePaid         Float             @default(0)
  remainingAmount     Float             @default(0)
  paymentMode         String?
  paymentStatus       String            @default("Pending")
  payment_status      String            @default("pending")
  payment_method      String            @default("upi")
  upi_reference       String?
  notes               String?
  adminNotes          String?
  sourceBookingLinkId String?
  salesAdminId        String?
  sourceMeta          Json?
  departureDate       DateTime?
  pickupCity          String?
  skipDays            Int?              @default(0)
  adjustedPrice       Float?
  joiningDate         DateTime?
  reminderSent        Boolean           @default(false)
  passengers          Json?
  trainTicketRequired Boolean           @default(false)
  trainTicketStatus   String            @default("NOT_REQUIRED")
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  tripRef             Trip              @relation(fields: [tripId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  emailLogs           BookingEmailLog[]
  emailLogsNew        EmailLog[]
  sourceBookingLink   BookingLink?      @relation(fields: [sourceBookingLinkId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  salesAdmin          Admin?            @relation("SalesBookings", fields: [salesAdminId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  // Verification & ticket relations
  verification          BookingVerification?
  trainTicket           TrainTicketRequest?
  trainTickets          TrainTicket[]
  trainTicketGroups     TrainTicketGroup[]
  activityLogs          BookingActivityLog[]
  tasks                 BookingTask[]
  accountingEntries     AccountingEntry[]
  opsVehicleAllocations OpsVehicleAllocation[]
  opsRoomAllocations    OpsRoomAllocation[]
  documents             BookingDocument[]
  ticketApprovals       TicketApproval[]
  opsClientPayments     OpsClientPayment[]

  @@index([tenantId])
  @@index([status])
  @@index([paymentStatus])
  @@index([sourceBookingLinkId])
  @@index([salesAdminId])
  @@index([tenantId, status, createdAt(sort: Desc)])
  @@index([tenantId, salesAdminId, status, createdAt(sort: Desc)])
}

model BookingDocument {
  id               String   @id @default(cuid())
  tenantId         String   @default("default")
  bookingId        String
  passengerId      String
  uploadedBy       String // admin ID or email/username
  documentType     String // generic file type or classification
  storagePath      String // private Supabase storage path or local fallback path
  originalFileName String
  mimeType         String
  fileSize         Int
  status           String   @default("UPLOADED") // UPLOADED / UPLOAD_FAILED
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([bookingId])
  @@index([passengerId])
  @@map("booking_documents")
}

model BookingEmailLog {
  id        String   @id @default(cuid())
  bookingId String
  type      String
  recipient String
  subject   String
  status    String
  error     String?
  sentAt    DateTime @default(now())
  metadata  Json?
  booking   Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([bookingId])
}

model BookingLink {
  id       String @id @default(cuid())
  tenantId String @default("default")

  createdByAdminId String?
  createdByAdmin   Admin?  @relation("CreatedBookingLinks", fields: [createdByAdminId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  tripId         String
  tripName       String?
  departureDate  DateTime?
  pickupCity     String?
  paymentMode    String?
  customAmount   Float?
  customTime     String?
  headerTitle    String?
  headerSubtitle String?
  customerName   String?
  customerPhone  String?
  customerEmail  String?
  travelerCount  Int?
  internalNote   String?

  expiresAt DateTime?
  status    String    @default("active") // active|revoked|expired

  tokenHash   String  @unique
  tokenPrefix String  @default("")
  // Admin needs to copy the exact share URL later; storing the URL keeps the token server-side.
  // Customers only see the URL they were already shared.
  shareUrl    String?

  openedCount     Int       @default(0)
  firstOpenedAt   DateTime?
  lastOpenedAt    DateTime?
  completedCount  Int       @default(0)
  lastCompletedAt DateTime?
  revokedAt       DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  events   BookingLinkEvent[]
  bookings Booking[]

  @@index([tenantId])
  @@index([status, createdAt(sort: Desc)])
  @@index([createdByAdminId, createdAt(sort: Desc)])
  @@index([createdByAdminId])
  @@index([tripId])
  @@index([status])
  @@index([expiresAt])
}

model BookingLinkEvent {
  id            String   @id @default(cuid())
  tenantId      String   @default("default")
  bookingLinkId String
  type          String
  ipHash        String?
  userAgent     String?
  createdAt     DateTime @default(now())

  bookingLink BookingLink @relation(fields: [bookingLinkId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([tenantId])
  @@index([bookingLinkId])
  @@index([type])
  @@index([createdAt])
}

model PageBuilder {
  id        String   @id @default(cuid())
  tenantId  String   @default("default")
  name      String   @unique
  sections  Json?    @default("[]")
  draft     Json?    @default("[]")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([name])
}

model Setting {
  id        String   @id @default(cuid())
  tenantId  String   @default("default")
  key       String   @unique
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([key])
}

model Theme {
  id        String   @id @default(cuid())
  tenantId  String   @default("default")
  name      String   @unique @default("primary")
  config    Json     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([name])
}

model DesignConfig {
  id        String   @id @default(cuid())
  tenantId  String   @default("default")
  scope     String // "global" | "page:{slug}" | "section:{pageSlug}:{sectionId}"
  config    Json     @default("{}")
  status    String   @default("draft") // "draft" | "published"
  version   Int      @default(1)
  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, scope, status])
  @@index([scope])
  @@index([status])
}

model DesignVersion {
  id               String   @id @default(cuid())
  tenantId         String   @default("default")
  scope            String
  config           Json
  version          Int
  action           String // "published" | "restored" | "draft_saved"
  changedBy        String?
  changedByName    String?
  changeSummary    String?
  affectedPages    String[] @default([])
  affectedSections String[] @default([])
  createdAt        DateTime @default(now())

  @@index([scope])
  @@index([createdAt])
}

model DesignPreset {
  id        String   @id @default(cuid())
  tenantId  String   @default("default")
  name      String
  category  String   @default("global") // "global" | "section" | "page"
  config    Json     @default("{}")
  isDefault Boolean  @default(false)
  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, name])
  @@index([category])
}

model Attraction {
  id            String   @id @default(cuid())
  tenantId      String   @default("default")
  name          String
  slug          String   @unique
  image         String?
  description   String?
  location      String?
  altitude      String?
  bestTime      String?
  category      String   @default("nature")
  visitingHours String?
  entryFee      String?
  etiquette     Json?
  faqs          Json?
  isFeatured    Boolean  @default(false)
  order         Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([tenantId])
  @@index([slug])
}

// ==========================================
// ACCESS CONTROL / RBAC / AUDIT LOG MODELS
// ==========================================

enum AdminRole {
  superadmin
  admin
  sales
  operations
  finance
  guide
  viewer
  BOOKING_VERIFIER
}

model TripAssignment {
  id        String   @id @default(cuid())
  tenantId  String?  @default("default")
  tripId    String
  guideId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  trip  Trip  @relation(fields: [tripId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  guide Admin @relation(fields: [guideId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([tripId, guideId])
  @@index([guideId])
  @@index([tripId])
}

model AuditLog {
  id          String   @id @default(cuid())
  tenantId    String?  @default("default")
  actorUserId String?
  action      String
  entityType  String?
  entityId    String?
  beforeData  Json?
  afterData   Json?
  ipAddress   String?
  createdAt   DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([actorUserId, createdAt])
  @@index([entityType, entityId])
}

// ==========================================
// BOOKING VERIFICATION & TRAIN TICKET MODELS
// ==========================================

model BookingVerification {
  id                String    @id @default(cuid())
  tenantId          String    @default("default")
  bookingId         String    @unique
  status            String    @default("DRAFT") // DRAFT, PENDING_VERIFICATION, CHANGES_REQUESTED, VERIFIED, REJECTED
  checklist         Json?
  notes             String?   @db.Text
  submittedAt       DateTime?
  verifiedAt        DateTime?
  verifiedByAdminId String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  booking    Booking                  @relation(fields: [bookingId], references: [bookingId], onDelete: Cascade)
  verifiedBy Admin?                   @relation("VerifiedByAdmin", fields: [verifiedByAdminId], references: [id])
  logs       BookingVerificationLog[]

  @@index([tenantId])
  @@index([status])
  @@index([tenantId, status, updatedAt(sort: Desc)])
  @@map("booking_verifications")
}

model BookingVerificationLog {
  id                    String   @id @default(cuid())
  bookingVerificationId String
  action                String // SUBMIT, VERIFY, REQUEST_CHANGES, REJECT
  notes                 String?  @db.Text
  snapshot              Json?
  adminId               String?
  createdAt             DateTime @default(now())

  verification BookingVerification @relation(fields: [bookingVerificationId], references: [id], onDelete: Cascade)
  admin        Admin?              @relation("VerificationLogAdmin", fields: [adminId], references: [id])

  @@index([bookingVerificationId])
  @@map("booking_verification_logs")
}

model TrainTicketRequest {
  id              String    @id @default(cuid())
  tenantId        String    @default("default")
  bookingId       String    @unique
  status          String    @default("DRAFT") // DRAFT, PENDING_VERIFICATION, CHANGES_REQUESTED, APPROVED, REJECTED, ISSUED, CANCELLED, REBOOKED
  journeyDate     DateTime?
  fromStation     String?
  toStation       String?
  preferredTrain  String?
  preferredClass  String?
  seatPreference  String?
  estimatedAmount Float?    @default(0)
  specialNotes    String?   @db.Text
  pnr             String?
  ticketDetails   String?   @db.Text
  history         Json?
  templateId      String?
  emailTemplateId String?
  alertMetadata   Json?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  booking    Booking                @relation(fields: [bookingId], references: [bookingId], onDelete: Cascade)
  travellers TrainTicketTraveller[]
  logs       TrainTicketLog[]

  @@index([tenantId])
  @@index([status])
  @@map("train_ticket_requests")
}

model TrainTicketTraveller {
  id                   String   @id @default(cuid())
  trainTicketRequestId String
  name                 String
  age                  Int?
  gender               String?
  phone                String?
  createdAt            DateTime @default(now())

  request TrainTicketRequest @relation(fields: [trainTicketRequestId], references: [id], onDelete: Cascade)

  @@index([trainTicketRequestId])
  @@map("train_ticket_travellers")
}

model TrainTicketLog {
  id                   String   @id @default(cuid())
  trainTicketRequestId String
  action               String // CREATE, SAVE_DRAFT, SUBMIT, APPROVE, REJECT, REQUEST_CHANGES, MARK_ISSUED
  notes                String?  @db.Text
  snapshot             Json?
  adminId              String?
  createdAt            DateTime @default(now())

  request TrainTicketRequest @relation(fields: [trainTicketRequestId], references: [id], onDelete: Cascade)
  admin   Admin?             @relation("TicketLogAdmin", fields: [adminId], references: [id])

  @@index([trainTicketRequestId])
  @@map("train_ticket_logs")
}

enum TrainTicketStatus {
  PENDING
  BOOKED
  WAITLISTED
  CONFIRMED
  RAC
  SELF_BOOKED
  CANCELLED
}

enum TrainTicketApprovalStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  REOPENED
}

model TrainTicket {
  id                   String                    @id @default(cuid())
  tenantId             String                    @default("default")
  bookingId            String
  travelerName         String
  passengerReference   String?
  pnr                  String?
  trainName            String?
  trainNumber          String?
  journeyDate          DateTime?
  sourceStation        String?
  destinationStation   String?
  coach                String?
  seatNumber           String?
  berthType            String?
  ticketStatus         TrainTicketStatus         @default(PENDING)
  approvalStatus       TrainTicketApprovalStatus @default(DRAFT)
  isLocked             Boolean                   @default(false)
  ticketAmount         Decimal                   @default(0.00) @db.Decimal(10, 2)
  amountMode           String?
  refundAmount         Decimal                   @default(0.00) @db.Decimal(10, 2)
  cancellationReason   String?
  internalNote         String?                   @db.Text
  ticketBookingPerson  String?
  supersedesTicketId   String?                   @unique
  supersededByTicketId String?                   @unique
  reopenReason         String?                   @db.Text
  submittedByAdminId   String?
  groupId              String?
  templateId           String?
  ticketFileUrl        String?

  // Relations
  booking      Booking               @relation(fields: [bookingId], references: [bookingId], onDelete: Cascade)
  supersedes   TrainTicket?          @relation("TicketSupersedes", fields: [supersedesTicketId], references: [id])
  supersededBy TrainTicket?          @relation("TicketSupersedes")
  submittedBy  Admin?                @relation("TicketSubmittedByAdmin", fields: [submittedByAdminId], references: [id], onDelete: SetNull)
  history      TrainTicketHistory[]
  approvals    TrainTicketApproval[]
  group        TrainTicketGroup?     @relation(fields: [groupId], references: [id], onDelete: SetNull)
  emailLogs    EmailLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([bookingId])
  @@index([pnr])
  @@index([ticketStatus])
  @@index([approvalStatus])
  @@index([journeyDate])
  @@index([tenantId, ticketStatus, journeyDate])
  @@index([tenantId, approvalStatus, updatedAt(sort: Desc)])
}

model TrainTicketHistory {
  id            String                     @id @default(cuid())
  ticketId      String
  action        String
  fromStatus    TrainTicketStatus?
  toStatus      TrainTicketStatus?
  fromApproval  TrainTicketApprovalStatus?
  toApproval    TrainTicketApprovalStatus?
  notes         String?                    @db.Text
  performedById String?
  createdAt     DateTime                   @default(now())

  ticket      TrainTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  performedBy Admin?      @relation("TicketHistoryAdmin", fields: [performedById], references: [id], onDelete: SetNull)

  @@index([ticketId])
  @@index([ticketId, createdAt])
}

model TrainTemplate {
  id                 String    @id @default(cuid())
  tenantId           String    @default("default")
  tripId             String?
  tripTitle          String?
  departureDate      DateTime?
  trainName          String?
  trainNumber        String?
  source             String?
  destination        String?
  defaultClass       String?
  defaultCoach       String?
  journeyDate        DateTime?
  boardingPoint      String?
  droppingPoint      String?
  waitlistDisclaimer String?   @db.Text
  isActive           Boolean   @default(true)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  trip Trip? @relation(fields: [tripId], references: [id], onDelete: SetNull)

  @@unique([tripId, departureDate, source, destination])
  @@index([tenantId])
  @@index([tripId, departureDate])
}

model TrainTicketAlert {
  id        String   @id @default(cuid())
  tenantId  String   @default("default")
  alertType String
  dedupeKey String
  bookingId String?
  ticketId  String?
  resolved  Boolean  @default(false)
  sentAt    DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([alertType, dedupeKey])
  @@index([tenantId])
  @@index([bookingId])
  @@index([bookingId, alertType])
  @@index([ticketId])
}

// ── NEW: TrainTicketGroup — supports PER_PERSON or GROUP_TOTAL amount modes ──
model TrainTicketGroup {
  id                String   @id @default(cuid())
  tenantId          String   @default("default")
  bookingId         String
  label             String?
  amountMode        String   @default("PER_PERSON") // PER_PERSON | GROUP_TOTAL
  groupTicketAmount Decimal? @db.Decimal(10, 2)
  createdByAdminId  String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  booking   Booking       @relation(fields: [bookingId], references: [bookingId], onDelete: Cascade)
  createdBy Admin?        @relation("GroupCreatedByAdmin", fields: [createdByAdminId], references: [id], onDelete: SetNull)
  tickets   TrainTicket[]

  @@index([tenantId])
  @@index([bookingId])
}

// ── NEW: TrainTicketApproval — immutable approval workflow history ──
model TrainTicketApproval {
  id                 String                     @id @default(cuid())
  tenantId           String                     @default("default")
  trainTicketId      String
  action             String // CREATE|EDIT|SUBMIT|APPROVE|REJECT|REQUEST_CORRECTION|REOPEN|CANCEL|REBOOK|BULK_UPDATE
  fromApprovalStatus TrainTicketApprovalStatus?
  toApprovalStatus   TrainTicketApprovalStatus?
  fromTicketStatus   TrainTicketStatus?
  toTicketStatus     TrainTicketStatus?
  notes              String?                    @db.Text
  actorAdminId       String?
  createdAt          DateTime                   @default(now())

  ticket     TrainTicket @relation(fields: [trainTicketId], references: [id], onDelete: Cascade)
  actorAdmin Admin?      @relation("ApprovalActorAdmin", fields: [actorAdminId], references: [id], onDelete: SetNull)

  @@index([trainTicketId, createdAt])
  @@index([tenantId])
}

// ── NEW: TicketApproval — booking-level approval gate for generated tickets (train/flight/bus) ──
model TicketApproval {
  id               String    @id @default(cuid())
  bookingId        String
  booking          Booking   @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  ticketType       String // "train" | "flight" | "bus"
  status           String    @default("pending") // pending | approved | rejected
  ticketNumber     String? // PNR or ticket ref, filled once generated
  ticketFileUrl    String? // uploaded ticket PDF/image if applicable
  requestedBy      String // user id who generated/requested it
  reviewedBy       String? // user id who approved/rejected
  requestedByAdmin Admin     @relation("TicketApprovalRequestedBy", fields: [requestedBy], references: [id])
  reviewedByAdmin  Admin?    @relation("TicketApprovalReviewedBy", fields: [reviewedBy], references: [id])
  reviewedAt       DateTime?
  rejectionNote    String?   @db.Text
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([bookingId])
  @@index([status])
}

// ── NEW: TrainTicketAlertEvent — deduplication table for future alert emails ──
model TrainTicketAlertEvent {
  id               String    @id @default(cuid())
  tenantId         String    @default("default")
  bookingId        String?
  trainTicketId    String?
  alertType        String // PENDING_2D | DEPARTURE_10D_URGENT
  dedupeKey        String
  recipientAdminId String?
  channel          String    @default("EMAIL") // EMAIL | WHATSAPP
  sentAt           DateTime?
  metadata         Json?
  createdAt        DateTime  @default(now())

  @@unique([alertType, dedupeKey])
  @@index([tenantId])
  @@index([bookingId, alertType])
  @@index([trainTicketId])
}

// ── NEW: Accounting Payment Mode Enum ──
enum AccountingPaymentMode {
  CASH
  UPI
  BANK_TRANSFER
}

// ── NEW: Accounting Entry Status Enum ──
enum AccountingEntryStatus {
  PENDING
  APPROVED
  REJECTED
}

// ── NEW: Accounting Entry Model ──
model AccountingEntry {
  id              String                @id @default(cuid())
  tenantId        String                @default("default")
  bookingId       String
  amount          Float
  paymentMode     AccountingPaymentMode
  referenceNumber String?
  status          AccountingEntryStatus @default(PENDING)
  notes           String?               @db.Text
  rejectionReason String?               @db.Text

  salespersonId String
  actionedById  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  booking     Booking              @relation(fields: [bookingId], references: [bookingId], onDelete: Cascade)
  salesperson Admin                @relation("SalesAccountingEntries", fields: [salespersonId], references: [id])
  actionedBy  Admin?               @relation("ActionedAccountingEntries", fields: [actionedById], references: [id])
  history     AccountingEntryLog[]

  @@index([tenantId])
  @@index([bookingId])
  @@index([salespersonId])
  @@index([status])
}

// ── NEW: Accounting Entry Log Model ──
model AccountingEntryLog {
  id                String   @id @default(cuid())
  accountingEntryId String
  action            String
  notes             String?  @db.Text
  actorId           String
  createdAt         DateTime @default(now())

  accountingEntry AccountingEntry @relation(fields: [accountingEntryId], references: [id], onDelete: Cascade)
  actor           Admin           @relation(fields: [actorId], references: [id])

  @@index([accountingEntryId])
}

// ── NEW: Accounting Alert Dedupe Model ──
model AccountingAlertDedupe {
  id        String   @id @default(cuid())
  alertType String
  bookingId String
  sentAt    DateTime @default(now())

  @@unique([alertType, bookingId])
  @@index([bookingId])
}

enum OpsVendorType {
  HOTEL
  HOMESTAY
  CAMP
  TRANSPORT
  GUIDE
  FOOD
  MEALS
  MISC
}

enum OpsBookingStatus {
  UNCONFIRMED
  CONFIRMED
  CANCELLED
}

enum OpsSOPStage {
  PRE_TRIP_30D
  PRE_TRIP_7D
  PRE_TRIP_1D
  DEPARTURE_DAY
  DURING_TRIP
  POST_TRIP
}

enum IncidentSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

// ── VENDOR DIRECTORY ENHANCEMENTS ──
model OpsVendor {
  id             String        @id @default(cuid())
  tenantId       String        @default("default")
  vendorCode     String?       @unique
  name           String
  type           OpsVendorType
  contactPerson  String?
  email          String?
  phone          String?
  alternatePhone String?
  state          String?
  location       String?       // represents city
  address        String?       @db.Text
  rating         Float?        @default(5.0)
  notes          String?       @db.Text
  isActive       Boolean       @default(true)
  sourceSheet    String?
  sourceRow      Int?
  totalRooms     Int?
  roomTypes      String?
  sharingTypes   String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  hotelBookings      OpsHotelBooking[]
  transportFleet     OpsTransportFleet[]
  guidePayments      OpsGuidePayment[]
  opsActivities      OpsActivity[]                  @relation("OpsActivityVendor")
  hotelRates         OpsVendorHotelRate[]
  accommodationRates OpsAccommodationRate[]
  transportRates     OpsTransportRate[]
  additionalCharges  OpsVendorAdditionalCharge[]
  opsAllocations     OpsDepartureVendorAllocation[]
  tripVendors        OpsTripVendor[]

  @@index([tenantId])
  @@index([type])
}

// ── HOTEL BOOKINGS TRACKER ──
model OpsHotelBooking {
  id            String           @id @default(cuid())
  tenantId      String           @default("default")
  tripId        String
  departureDate DateTime         @db.Date
  vendorId      String?
  hotelName     String
  location      String?
  checkIn       DateTime?
  checkOut      DateTime?
  roomType      String?
  numberOfRooms Int              @default(1)
  confirmed     OpsBookingStatus @default(UNCONFIRMED)
  totalAmount   Float            @default(0)
  advancePaid   Float            @default(0)
  balanceAmount Float            @default(0)
  contactPerson String?
  contactPhone  String?
  notes         String?          @db.Text
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  // Snapshot Fields
  rateId           String?
  rateType         String?          @default("PER_ROOM_PER_NIGHT")
  doubleRate       Float?
  tripleRate       Float?
  quadRate         Float?
  singleRate       Float?
  extraBedRate     Float?
  childWithBed     Float?
  childWithoutBed  Float?
  mealPlanRate     Float?
  taxPercent       Float?           @default(0)
  rateValidFrom    DateTime?
  rateValidUntil   DateTime?
  rateSnapshotAt   DateTime?

  // Allocations
  pricingMethod    String?          @default("room-wise")
  doubleRoomsCount Int?             @default(0)
  tripleRoomsCount Int?             @default(0)
  quadRoomsCount   Int?             @default(0)
  extraPersonsCount Int?            @default(0)
  nightsCount      Int?             @default(1)

  trip   Trip       @relation(fields: [tripId], references: [id], onDelete: Restrict)
  vendor OpsVendor? @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  overrides DepartureHotelRateOverride[]

  @@index([tenantId])
  @@index([tripId, departureDate])
}

// ── PERSISTENT VENDOR HOTEL RATES ──
model OpsVendorHotelRate {
  id              String    @id @default(cuid())
  tenantId        String    @default("default")
  vendorId        String
  rateName        String?
  rateType        String    @default("PER_ROOM_PER_NIGHT") // PER_ROOM_PER_NIGHT | PER_PERSON_PER_NIGHT
  doubleRate      Float?
  tripleRate      Float?
  quadRate        Float?
  singleRate      Float?
  extraBedRate    Float?
  childWithBed    Float?
  childWithoutBed Float?
  mealPlan        String?
  mealPlanRate    Float?
  taxPercent      Float?    @default(0)
  validFrom       DateTime?
  validUntil      DateTime?
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  vendor          OpsVendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@index([vendorId])
  @@index([validFrom, validUntil])
}

// ── DEPARTURE-SPECIFIC OVERRIDES ──
model DepartureHotelRateOverride {
  id                  String   @id @default(cuid())
  departureHotelId    String
  fieldName           String
  originalValue       Float
  overriddenValue     Float
  reason              String
  overriddenById      String
  createdAt           DateTime @default(now())

  departureHotel      OpsHotelBooking @relation(fields: [departureHotelId], references: [id], onDelete: Cascade)

  @@index([departureHotelId])
}

// ── ROOM INVENTORY (Available rooms for allocation) ──
model OpsRoomInventory {
  id            String   @id @default(cuid())
  tenantId      String   @default("default")
  tripId        String
  departureDate DateTime @db.Date
  roomLabel     String
  roomType      String   @default("TWIN")
  genderGroup   String   @default("BOYS")
  capacity      Int      @default(2)
  hotelName     String?
  notes         String?  @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Restrict)

  @@index([tenantId])
  @@index([tripId, departureDate])
}

// ── TRANSPORT FLEET TRACKER ──
model OpsTransportFleet {
  id                 String    @id @default(cuid())
  tenantId           String    @default("default")
  tripId             String
  departureDate      DateTime  @db.Date
  vendorId           String?
  vehicleType        String
  vehicleNumber      String?                          // registration plate e.g. HP-01-AB-1234
  capacity           Int       @default(13)
  route              String?
  pickupPoints       String?
  dropPoints         String?
  reportingTime      String?                          // HH:MM — when vehicle should report
  departureTime      String?                          // HH:MM — scheduled departure
  confirmationStatus String    @default("UNCONFIRMED") // UNCONFIRMED | CONFIRMED | CANCELLED
  paymentDueDate     DateTime?
  totalAmount        Float     @default(0)
  advancePaid        Float     @default(0)
  balanceAmount      Float     @default(0)
  driverName         String?
  driverPhone        String?
  notes              String?   @db.Text
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  trip        Trip                   @relation(fields: [tripId], references: [id], onDelete: Restrict)
  vendor      OpsVendor?             @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  allocations OpsVehicleAllocation[]

  @@index([tenantId])
  @@index([tripId, departureDate])
}

// ── GUIDE PAYMENTS TRACKER ──
model OpsGuidePayment {
  id                 String    @id @default(cuid())
  tenantId           String    @default("default")
  tripId             String
  departureDate      DateTime  @db.Date
  guideAdminId       String?                          // FK → Admin (internal guide from directory)
  vendorId           String?                          // FK → OpsVendor type=GUIDE (external guide vendor)
  guideName          String                           // display name (from Admin.name or free-text)
  assignmentType     String    @default("PRIMARY_GUIDE") // PRIMARY_GUIDE | CO_GUIDE | LOCAL_GUIDE | SUPPORT_STAFF
  assignmentStatus   String    @default("ASSIGNED")   // ASSIGNED | ACCEPTED | CONFIRMED | DECLINED | REPLACED | CANCELLED
  startDate          DateTime? @db.Date               // guide availability start
  endDate            DateTime? @db.Date               // guide availability end
  reportingLocation  String?
  reportingTime      String?                          // HH:MM
  emergencyContact   String?
  daysWorked         Int       @default(1)
  agreedAmount       Float     @default(0)
  advancePaid        Float     @default(0)
  balanceAmount      Float     @default(0)
  paymentStatus      String    @default("PENDING")
  approvedById       String?
  notes              String?   @db.Text
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  trip       Trip       @relation(fields: [tripId], references: [id], onDelete: Restrict)
  guideAdmin Admin?     @relation("GuideAssignments", fields: [guideAdminId], references: [id])
  approvedBy Admin?     @relation("GuidePaymentApprovals", fields: [approvedById], references: [id])
  vendor     OpsVendor? @relation(fields: [vendorId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([tripId, departureDate])
}

// ── OPERATIONAL MISC EXPENSES ──
model OpsMiscExpense {
  id            String   @id @default(cuid())
  tenantId      String   @default("default")
  tripId        String
  departureDate DateTime @db.Date
  category      String
  description   String
  amount        Float    @default(0)
  createdAt     DateTime @default(now())

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Restrict)

  @@index([tripId, departureDate])
}

// ── SEAT MANAGEMENT CONFIG & ALERTS ──
model OpsSeatConfig {
  id             String   @id @default(cuid())
  tenantId       String   @default("default")
  tripId         String
  departureDate  DateTime @db.Date
  totalSeatsCap  Int      @default(30)
  alertThreshold Int      @default(25)
  blockedSeats   Int      @default(0)
  alertSent      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Restrict)

  @@unique([tenantId, tripId, departureDate])
}

// ── TRIP SOP LIBRARY ──
model OpsSOPTemplate {
  id          String      @id @default(cuid())
  tenantId    String      @default("default")
  destination String
  stage       OpsSOPStage
  taskName    String
  description String?     @db.Text
  createdAt   DateTime    @default(now())

  @@index([tenantId, destination])
}

// ── TRIP-WISE CHECKLIST ITEM ──
model OpsTripChecklist {
  id            String      @id @default(cuid())
  tenantId      String      @default("default")
  tripId        String
  departureDate DateTime    @db.Date
  stage         OpsSOPStage
  taskName      String
  isCompleted   Boolean     @default(false)
  completedById String?
  completedAt   DateTime?
  notes         String?
  assignedTo    String? // OPERATIONS, GUIDE, FINANCE, etc.
  priority      String      @default("MEDIUM") // LOW, MEDIUM, HIGH
  dueDate       DateTime?
  status        String      @default("Pending") // Pending, In Progress, Completed, Overdue
  remarks       String?     @db.Text

  trip        Trip                   @relation(fields: [tripId], references: [id], onDelete: Restrict)
  completedBy Admin?                 @relation("ChecklistCompletedByAdmin", fields: [completedById], references: [id], onDelete: Restrict)
  activities  OpsChecklistActivity[]

  @@index([tripId, departureDate, stage])
}

// ── CHECKLIST ITEM ACTIVITY LOG ──
model OpsChecklistActivity {
  id              String             @id @default(cuid())
  tenantId        String             @default("default")
  checklistItemId String
  action          OpsChecklistAction
  previousStatus  Boolean
  nextStatus      Boolean
  notes           String?            @db.Text
  actorId         String
  createdAt       DateTime           @default(now())

  checklist OpsTripChecklist @relation(fields: [checklistItemId], references: [id], onDelete: Restrict)
  actor     Admin            @relation(fields: [actorId], references: [id], onDelete: Restrict)

  @@index([tenantId])
  @@index([checklistItemId])
}

// ── INCIDENT / ISSUE LOG ──
model OpsIncidentLog {
  id            String            @id @default(cuid())
  tenantId      String            @default("default")
  tripId        String
  departureDate DateTime          @db.Date
  title         String
  severity      IncidentSeverity  @default(MEDIUM)
  description   String            @db.Text
  resolution    String?           @db.Text
  reportedById  String
  incidentType  OpsIncidentType   @default(OTHER)
  status        OpsIncidentStatus @default(OPEN)
  resolvedById  String?
  resolvedAt    DateTime?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  trip       Trip                  @relation(fields: [tripId], references: [id], onDelete: Restrict)
  reportedBy Admin                 @relation("IncidentReportedByAdmin", fields: [reportedById], references: [id], onDelete: Restrict)
  resolvedBy Admin?                @relation("IncidentResolvedByAdmin", fields: [resolvedById], references: [id], onDelete: Restrict)
  activities OpsIncidentActivity[]

  @@index([tripId, departureDate])
}

// ── INCIDENT ACTIVITY LOG ──
model OpsIncidentActivity {
  id         String                    @id @default(cuid())
  tenantId   String                    @default("default")
  incidentId String
  action     OpsIncidentActivityAction
  notes      String?                   @db.Text
  actorId    String
  createdAt  DateTime                  @default(now())

  incident OpsIncidentLog @relation(fields: [incidentId], references: [id], onDelete: Restrict)
  actor    Admin          @relation(fields: [actorId], references: [id], onDelete: Restrict)

  @@index([tenantId])
  @@index([incidentId])
}

// ── AUTO ALLOCATION RUN & OVERRIDE MODELS ──
model OpsAllocationRun {
  id            String   @id @default(cuid())
  tenantId      String   @default("default")
  tripId        String
  departureDate DateTime @db.Date
  version       Int      @default(1)
  status        String   @default("DRAFT") // DRAFT | CONFIRMED
  resultJson    Json
  actorId       String?
  createdAt     DateTime @default(now())

  trip      Trip                    @relation(fields: [tripId], references: [id], onDelete: Restrict)
  actor     Admin?                  @relation(fields: [actorId], references: [id], onDelete: SetNull)
  overrides OpsAllocationOverride[]

  @@index([tenantId, tripId, departureDate])
}

model OpsAllocationOverride {
  id              String   @id @default(cuid())
  tenantId        String   @default("default")
  allocationRunId String
  targetType      String // VEHICLE | ROOM
  targetId        String
  beforeValue     Json?
  afterValue      Json
  reason          String   @db.Text
  actorId         String
  createdAt       DateTime @default(now())

  run   OpsAllocationRun @relation(fields: [allocationRunId], references: [id], onDelete: Restrict)
  actor Admin            @relation(fields: [actorId], references: [id], onDelete: Restrict)

  @@index([allocationRunId])
}

model OpsVehicleAllocation {
  id               String   @id @default(cuid())
  tripId           String
  departureDate    DateTime @db.Date
  fleetId          String
  bookingId        String
  travelerName     String
  seatNumber       Int?
  allocationStatus String   @default("ACTIVE") // ACTIVE | CANCELLED
  routeSegment     String?                     // e.g. pickup-point tag
  pickupPoint      String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  trip    Trip              @relation(fields: [tripId], references: [id], onDelete: Restrict)
  fleet   OpsTransportFleet @relation(fields: [fleetId], references: [id], onDelete: Restrict)
  booking Booking           @relation(fields: [bookingId], references: [bookingId], onDelete: Restrict)

  @@unique([tripId, departureDate, bookingId, travelerName]) // prevent duplicate passenger allocation
  @@index([tripId, departureDate])
  @@index([fleetId])
  @@index([bookingId])
}

model OpsRoomAllocation {
  id               String   @id @default(cuid())
  tripId           String
  departureDate    DateTime @db.Date
  roomNumber       String
  roomType         String
  genderGroup      String
  bookingId        String
  travelerName     String
  sharingType      String   @default("STANDARD") // TWIN|TRIPLE|QUAD|EXTRA_BED|COUPLE|SINGLE|GUIDE_STAFF|COMPLIMENTARY
  allocationStatus String   @default("ACTIVE")   // ACTIVE | CANCELLED | NIGHT_JOURNEY_BLOCKED
  hotelBookingId   String?                        // FK → OpsHotelBooking (nullable for backward compat)
  notes            String?  @db.Text
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  trip    Trip    @relation(fields: [tripId], references: [id], onDelete: Restrict)
  booking Booking @relation(fields: [bookingId], references: [bookingId], onDelete: Restrict)

  @@unique([tripId, departureDate, bookingId, travelerName]) // prevent duplicate passenger allocation
  @@index([tripId, departureDate])
  @@index([hotelBookingId])
}

// ── DAY ITINERARY GRID (EXCEL SHEET MATCH) ──
model OpsDayItinerary {
  id                 String    @id @default(cuid())
  tenantId           String    @default("default")
  tripId             String
  departureDate      DateTime  @db.Date
  date               DateTime?
  dayTitle           String
  paxCount           Int       @default(0)
  hotelName          String?
  hotelVerified      Boolean   @default(false)
  vehicleType        String?
  vehicleVerified    Boolean   @default(false)
  remarks            String?   @db.Text
  guideDriverDetails String?
  guideVerified      Boolean   @default(false)
  checkInDone        Boolean   @default(false)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Restrict)

  @@index([tripId, departureDate])
}

// ── TRIP DETAILED EXPENSE GRID (EXCEL SHEET MATCH) ──
model OpsTripExpense {
  id            String    @id @default(cuid())
  tenantId      String    @default("default")
  tripId        String
  departureDate DateTime  @db.Date
  serviceDate   DateTime?
  activity      String
  paymentDate   DateTime?
  totalAmount   Float     @default(0)
  amountPaid    Float     @default(0)
  dueAmount     Float     @default(0)
  paymentStatus String    @default("Due")
  remarks       String?   @db.Text
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Restrict)

  @@index([tripId, departureDate])
}

// ── SOP LIBRARY (Destination operating instructions only) ──
model OpsSopLibrary {
  id           String    @id @default(cuid())
  tenantId     String    @default("default")
  destination  String
  title        String
  content      String    @db.Text
  isActive     Boolean   @default(true)
  createdById  String?
  updatedById  String?
  archivedAt   DateTime?
  archivedById String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdBy  Admin? @relation("SopCreatedByAdmin", fields: [createdById], references: [id], onDelete: Restrict)
  updatedBy  Admin? @relation("SopUpdatedByAdmin", fields: [updatedById], references: [id], onDelete: Restrict)
  archivedBy Admin? @relation("SopArchivedByAdmin", fields: [archivedById], references: [id], onDelete: Restrict)

  @@index([tenantId])
  @@index([destination])
}

// ── TRIP LEADER ASSIGNMENT (Departure scoped) ──
model OpsTripLeader {
  id            String   @id @default(cuid())
  tenantId      String   @default("default")
  tripId        String
  departureDate DateTime @db.Date

  leaderName  String
  leaderPhone String
  leaderType  OpsLeaderType @default(INTERNAL)
  isPrimary   Boolean       @default(false)
  notes       String?       @db.Text

  assignedById String?
  updatedById  String?
  archivedAt   DateTime?
  archivedById String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  trip       Trip                    @relation(fields: [tripId], references: [id], onDelete: Restrict)
  assignedBy Admin?                  @relation("LeaderAssignedByAdmin", fields: [assignedById], references: [id], onDelete: Restrict)
  updatedBy  Admin?                  @relation("LeaderUpdatedByAdmin", fields: [updatedById], references: [id], onDelete: Restrict)
  archivedBy Admin?                  @relation("LeaderArchivedByAdmin", fields: [archivedById], references: [id], onDelete: Restrict)
  activities OpsTripLeaderActivity[]

  @@unique([tenantId, tripId, departureDate, leaderPhone])
  @@index([tenantId, tripId, departureDate])
}

// ── TRIP LEADER ACTIVITY LOG ──
model OpsTripLeaderActivity {
  id                 String                  @id @default(cuid())
  tenantId           String                  @default("default")
  leaderAssignmentId String
  action             OpsLeaderActivityAction
  beforeValue        Json?
  afterValue         Json?
  notes              String?                 @db.Text
  actorId            String
  createdAt          DateTime                @default(now())

  leader OpsTripLeader @relation(fields: [leaderAssignmentId], references: [id], onDelete: Restrict)
  actor  Admin         @relation(fields: [actorId], references: [id], onDelete: Restrict)

  @@index([tenantId])
  @@index([leaderAssignmentId])
}

// ── ENUMS ──
