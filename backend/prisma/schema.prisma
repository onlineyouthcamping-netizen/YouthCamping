  vendorId        String
  vendor          DirectoryVendor  @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  contractStatus  String           @default("DRAFT") // DRAFT | SIGNED | EXPIRED
  validFrom       DateTime?
  validTo         DateTime?
  terms           String?          @db.Text
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([vendorId])
}

model DirectoryVendorPayment {
  id              String           @id @default(cuid())
  vendorId        String
  vendor          DirectoryVendor  @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  tripId          String?
  departureDate   DateTime?        @db.Date
  invoiceAmount   Decimal          @db.Decimal(12, 2)
  advanceAmount   Decimal          @db.Decimal(12, 2)          @default(0.0)
