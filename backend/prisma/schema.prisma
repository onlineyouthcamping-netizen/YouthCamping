// ==========================================
// PACKAGE BUILDER MODULE
// ==========================================

// ── State / Region ──
model PackageState {
  id        String   @id @default(cuid())
  tenantId  String   @default("default")
  name      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cities PackageCity[]

  @@index([tenantId])
}

// ── Destination / City ──
model PackageCity {
  id        String   @id @default(cuid())
  tenantId  String   @default("default")
  stateId   String
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  state         PackageState           @relation(fields: [stateId], references: [id], onDelete: Cascade)
  hotels        PackageHotel[]
  vehicles      PackageVehicle[]
  activities    PackageActivity[]
  transferFrom  PackageTransferRoute[] @relation("TransferFromCity")
  transferTo    PackageTransferRoute[] @relation("TransferToCity")
  itineraryDays PackageItineraryDay[]

  @@unique([tenantId, stateId, name])
  @@index([tenantId])
  @@index([stateId])
}

// ── Vendor (Package-specific) ──
model PackageVendor {
  id            String   @id @default(cuid())
  tenantId      String   @default("default")
  name          String
  type          String // HOTEL | VEHICLE | ACTIVITY | MEALS | GUIDE | OTHER
  contactPerson String?
  email         String?
  phone         String?
  location      String?
  gstNumber     String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  hotels     PackageHotel[]
  vehicles   PackageVehicle[]
  activities PackageActivity[]
  meals      PackageMealPlan[]

  @@index([tenantId])
  @@index([type])
}

// ── Hotel / Resort ──
model PackageHotel {
  id                   String   @id @default(cuid())
  tenantId             String   @default("default")
  cityId               String
  name                 String
  category             String // Budget | Standard | Deluxe | Premium | Luxury
  roomType             String // Standard | Deluxe | Super Deluxe | Premium | Suite
  maxPeoplePerRoom     Int      @default(2)
  mealPlan             String // EP | CP | MAP | AP
  basePrice            Float    @default(0)
  weekendPrice         Float?
  peakSeasonPrice      Float?
  extraMattressPrice   Float?   @default(0)
  extraAdultPrice      Float?   @default(0)
  childWithBedPrice    Float?   @default(0)
  childWithoutBedPrice Float?   @default(0)
  images               String[] @default([])
  vendorId             String?
  contactName          String?
  contactPhone         String?
  isActive             Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  city    PackageCity          @relation(fields: [cityId], references: [id], onDelete: Cascade)
  vendor  PackageVendor?       @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  tariffs PackageHotelTariff[]

  @@index([tenantId])
  @@index([cityId])
  @@index([category])
}

// ── Seasonal Hotel Tariff ──
model PackageHotelTariff {
  id        String   @id @default(cuid())
  hotelId   String
  startDate DateTime @db.Date
  endDate   DateTime @db.Date
  roomRate  Float    @default(0)
  label     String? // "Peak Season", "Weekend", "Diwali", etc.

  hotel PackageHotel @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@index([hotelId])
  @@index([startDate, endDate])
}

// ── Vehicle / Transportation ──
model PackageVehicle {
  id              String   @id @default(cuid())
  tenantId        String   @default("default")
  cityId          String
  name            String // Ertiga, Innova, Crysta, Tempo Traveller, Bus, Volvo
  seatingCapacity Int
  isAc            Boolean  @default(true)
  image           String?
  vendorId        String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  city    PackageCity            @relation(fields: [cityId], references: [id], onDelete: Cascade)
  vendor  PackageVendor?         @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  tariffs PackageVehicleTariff[]

  @@index([tenantId])
  @@index([cityId])
}

// ── Vehicle Pricing ──
model PackageVehicleTariff {
  id                  String  @id @default(cuid())
  vehicleId           String
  priceType           String // PER_DAY | PER_KM | FIXED_ROUTE | AIRPORT | RAILWAY
  perDayRate          Float?
  perKmRate           Float?
  fixedRouteRate      Float?
  minKmPerDay         Int?    @default(0)
  driverAllowance     Float?  @default(0)
  fuelIncluded        Boolean @default(true)
  tollParkingIncluded Boolean @default(false)
  notes               String?

  vehicle PackageVehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId])
}

// ── Transfer Route ──
model PackageTransferRoute {
  id               String   @id @default(cuid())
  tenantId         String   @default("default")
  fromCityId       String
  toCityId         String
  distanceKm       Float?
  travelTimeMins   Int?
  suggestedVehicle String?
  fixedRate        Float?
  perKmRate        Float?
  pickupDropNotes  String?
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  fromCity PackageCity @relation("TransferFromCity", fields: [fromCityId], references: [id], onDelete: Cascade)
  toCity   PackageCity @relation("TransferToCity", fields: [toCityId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([fromCityId])
  @@index([toCityId])
}

// ── Activity / Sightseeing ──
model PackageActivity {
  id            String   @id @default(cuid())
  tenantId      String   @default("default")
  cityId        String
  name          String
  adultRate     Float    @default(0)
  childRate     Float    @default(0)
  isShared      Boolean  @default(true)
  duration      String? // "2 hrs", "Half Day", "Full Day"
  description   String?
  includedItems String?  @db.Text
  excludedItems String?  @db.Text
  image         String?
  vendorId      String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  city   PackageCity    @relation(fields: [cityId], references: [id], onDelete: Cascade)
  vendor PackageVendor? @relation(fields: [vendorId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([cityId])
}

// ── Meal Plan ──
model PackageMealPlan {
  id              String   @id @default(cuid())
  tenantId        String   @default("default")
  vendorId        String?
  name            String // "EP", "CP", "MAP", "AP" or custom
  breakfastCost   Float?   @default(0)
  lunchCost       Float?   @default(0)
  dinnerCost      Float?   @default(0)
  perPersonPerDay Float?   @default(0)
  description     String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  vendor PackageVendor? @relation(fields: [vendorId], references: [id], onDelete: SetNull)

  @@index([tenantId])
}

// ── Package Draft / Quote ──
model PackageDraft {
  id       String @id @default(cuid())
  tenantId String @default("default")
  draftId  String @unique
  status   String @default("draft") // draft | template | quoted | converted

  // Customer
  customerName    String?
  customerPhone   String?
  customerEmail   String?
  customerAddress String?

  // Package details
  packageName     String?
  stateId         String?
  departureCity   String?
  travelStartDate DateTime? @db.Date
  travelEndDate   DateTime? @db.Date
  totalNights     Int       @default(0)
  totalDays       Int       @default(0)
  adults          Int       @default(0)
  children        Int       @default(0)
  couples         Int       @default(0)
  totalRooms      Int       @default(0)
  roomConfig      Json? // room allocation details
  specialNotes    String?   @db.Text
  inclusions      String?   @db.Text
  exclusions      String?   @db.Text
  terms           String?   @db.Text

  // Pricing (recalculated server-side)
  hotelCost     Float   @default(0)
  vehicleCost   Float   @default(0)
  transferCost  Float   @default(0)
  activityCost  Float   @default(0)
  mealCost      Float   @default(0)
  guideCost     Float   @default(0)
  trainCost     Float   @default(0)
  flightCost    Float   @default(0)
  miscCost      Float   @default(0)
  subtotal      Float   @default(0)
  discount      Float   @default(0)
  discountType  String? // percentage | fixed
  gstRate       Float   @default(5)
  gstAmount     Float   @default(0)
  serviceCharge Float   @default(0)
  totalAmount   Float   @default(0)

  // Internal vendor costs (hidden from sales)
  vendorHotelCost    Float @default(0)
  vendorVehicleCost  Float @default(0)
  vendorActivityCost Float @default(0)
  vendorMealCost     Float @default(0)
  vendorGuideCost    Float @default(0)
  estimatedMargin    Float @default(0)

  // Quote
  quoteNumber   String?
  quoteValidity String?   @default("48 hours")
  paymentTerms  String?   @default("50% advance, 50% before travel")
  quoteSentAt   DateTime?

  // Audit
  salesAdminId String?
  createdById  String?
  updatedById  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  salesAdmin    Admin?                @relation("SalesPackageDrafts", fields: [salesAdminId], references: [id], onDelete: SetNull)
  createdBy     Admin?                @relation("PackageDraftCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy     Admin?                @relation("PackageDraftUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  itineraryDays PackageItineraryDay[]

  @@index([tenantId])
  @@index([status])
  @@index([salesAdminId])
  @@index([tenantId, status, createdAt(sort: Desc)])
}

// ── Itinerary Day ──
model PackageItineraryDay {
  id             String    @id @default(cuid())
  draftId        String
  dayNumber      Int
  date           DateTime? @db.Date
  stayCityId     String?
  title          String? // Optional custom title
  routeFrom      String?
  routeTo        String?
  distanceKm     Float?
  travelTimeMins Int?
  notes          String?   @db.Text

  draft    PackageDraft           @relation(fields: [draftId], references: [id], onDelete: Cascade)
  stayCity PackageCity?           @relation(fields: [stayCityId], references: [id], onDelete: SetNull)
  items    PackageItineraryItem[]

  @@index([draftId])
  @@index([dayNumber])
}

// ── Itinerary Item (service assigned to a day) ──
model PackageItineraryItem {
  id           String  @id @default(cuid())
  dayId        String
  serviceType  String // HOTEL | VEHICLE | TRANSFER | ACTIVITY | MEAL | GUIDE | TRAIN | FLIGHT | CUSTOM
  serviceId    String? // ID of the master record (PackageHotel.id, etc.)
  label        String // Display name
  description  String? @db.Text
  quantity     Int     @default(1)
  rate         Float   @default(0)
  amount       Float   @default(0)
  isVendorCost Boolean @default(false)
  sortOrder    Int     @default(0)
  metadata     Json? // Extra data (room type, meal plan, vehicle type, etc.)

  day PackageItineraryDay @relation(fields: [dayId], references: [id], onDelete: Cascade)

  @@index([dayId])
}

// ── Package Activity Log (audit trail) ──
model PackageActivityLog {
  id         String   @id @default(cuid())
  tenantId   String   @default("default")
  draftId    String?
  action     String
  details    String?  @db.Text
  actorId    String?
  beforeData Json?
  afterData  Json?
  createdAt  DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([draftId])
}

// ==========================================
// TRAVEL DESK MODULE
// ==========================================

// ── TICKETING SOPs ──
model TicketingSop {
  id          String   @id @default(cuid())
  tripId      String
  category    String // e.g. "train", "flight", "bus", "cancellation"
  title       String
  description String   @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  trip  Trip               @relation(fields: [tripId], references: [id], onDelete: Cascade)
  items TicketingSopItem[]

  @@index([tripId])
  @@index([category])
}

model TicketingSopItem {
  id        String   @id @default(cuid())
  sopId     String
  title     String
  content   String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sop TicketingSop @relation(fields: [sopId], references: [id], onDelete: Cascade)

  @@index([sopId])
}

// ── TICKETING QUICK LINKS ──
model TicketingLink {
  id        String   @id @default(cuid())
  tripId    String
  label     String
  val       String
  icon      String
  linkUrl   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([tripId])
}

// ── ITINERARY (parent: supports multiple variants) ──
model Itinerary {
  id        String   @id @default(cuid())
  tripId    String
  name      String
  isDefault Boolean  @default(false)
  version   Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  trip       Trip                 @relation(fields: [tripId], references: [id], onDelete: Cascade)
  days       ItineraryDay[]
  routeMaps  ItineraryRouteMap[]
  inclusions ItineraryInclusion[]
  exclusions ItineraryExclusion[]
  notes      ItineraryNote[]

  @@index([tripId])
}

model ItineraryDay {
  id          String   @id @default(cuid())
  itineraryId String
  dayNumber   String
  dayDate     String
  plan        String   @db.Text
  stay        String
  meals       String
  transport   String
  distance    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  itinerary Itinerary @relation(fields: [itineraryId], references: [id], onDelete: Cascade)

  @@index([itineraryId])
}

model ItineraryRouteMap {
  id          String   @id @default(cuid())
  itineraryId String
  mapUrl      String?
  description String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  itinerary Itinerary @relation(fields: [itineraryId], references: [id], onDelete: Cascade)

  @@index([itineraryId])
}

model ItineraryInclusion {
  id          String   @id @default(cuid())
  itineraryId String
  text        String   @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  itinerary Itinerary @relation(fields: [itineraryId], references: [id], onDelete: Cascade)

  @@index([itineraryId])
}

model ItineraryExclusion {
  id          String   @id @default(cuid())
  itineraryId String
  text        String   @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  itinerary Itinerary @relation(fields: [itineraryId], references: [id], onDelete: Cascade)

  @@index([itineraryId])
}

model ItineraryNote {
  id          String   @id @default(cuid())
  itineraryId String
  title       String
  body        String   @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  itinerary Itinerary @relation(fields: [itineraryId], references: [id], onDelete: Cascade)

  @@index([itineraryId])
}

// ── TRIP SOPs (Travel Desk) ──
model TripSop {
  id          String   @id @default(cuid())
  tripId      String
  title       String
  description String   @db.Text
  category    String
  icon        String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  trip  Trip          @relation(fields: [tripId], references: [id], onDelete: Cascade)
  items TripSopItem[]

  @@index([tripId])
}

model TripSopItem {
  id        String   @id @default(cuid())
  sopId     String
  title     String
  content   String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sop TripSop @relation(fields: [sopId], references: [id], onDelete: Cascade)

  @@index([sopId])
}

// ── TRIP DOCUMENTS ──
model TripDocument {
  id               String   @id @default(cuid())
  tripId           String
  name             String
  category         String
  fileType         String
  size             String?
  addedBy          String
  dateAdded        DateTime @default(now())
  fileUrl          String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  title            String   @default("")
  version          Int      @default(1)
  visibility       String   @default("internal")
  validFrom        DateTime?
  validUntil       DateTime?
  status           String   @default("DRAFT")
  uploadedBy       String   @default("system")
  approvalDetails  Json?
  knowledgeItems   KnowledgeItem[]

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([tripId])
}

model KnowledgeItem {
  id            String        @id @default(cuid())
  tripId        String
  documentId    String?
  sourceDocName String
  pageNumber    Int
  title         String
  content       String        @db.Text
  category      String
  version       Int           @default(1)
  status        String        @default("DRAFT")
  approvedBy    String?
  approvedAt    DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  trip          Trip          @relation(fields: [tripId], references: [id], onDelete: Cascade)
  document      TripDocument? @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([tripId])
  @@index([category])
  @@index([status])
}

model TravelQuestion {
  id             String    @id @default(cuid())
  tripId         String
  question       String    @db.Text
  answer         String?   @db.Text
  status         String    @default("OPEN")
  escalatedTo    String
  assignedToId   String?
  assignedToName String?
  createdBy      String
  createdById    String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  trip           Trip      @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([tripId])
  @@index([status])
}

// ── TRIP GALLERY ──
model TripGallery {
  id        String   @id @default(cuid())
  tripId    String
  title     String
  imageUrl  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([tripId])
}

// ── TRIP NOTES & UPDATES ──
model TripNote {
  id        String   @id @default(cuid())
  tripId    String
  title     String
  content   String?  @db.Text
  category  String
  linkUrl   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([tripId])
  @@index([category])
}

// ── ANNOUNCEMENTS ──
model Announcement {
  id        String   @id @default(cuid())
  tenantId  String   @default("default")
  title     String
  author    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
}

// ── DEPARTURE-WISE ACTIVITIES ──
model OpsActivity {
  id                 String    @id @default(cuid())
  tenantId           String    @default("default")
  tripId             String
  departureDate      DateTime  @db.Date
  dayNumber          Int       @default(1)
  date               DateTime?
  name               String
  type               String
  startTime          String?
  endTime            String?
  location           String?
  description        String?   @db.Text
  responsibleGuideId String?
  responsibleStaff   String?
  vendorId           String?
  vendorName         String?
  estimatedCost      Float     @default(0)
  actualCost         Float     @default(0)
  maxParticipants    Int       @default(0)
  safetyInstructions String?   @db.Text
  requiredEquipment  String?   @db.Text
  status             String    @default("Planned") // Planned, Confirmed, In Progress, Completed, Cancelled
  remarks            String?   @db.Text
  order              Int       @default(0)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  trip             Trip       @relation(fields: [tripId], references: [id], onDelete: Restrict)
  responsibleGuide Admin?     @relation("OpsActivityGuide", fields: [responsibleGuideId], references: [id])
  vendor           OpsVendor? @relation("OpsActivityVendor", fields: [vendorId], references: [id])

  @@index([tenantId])
  @@index([tripId, departureDate])
}

// ── NEW: VENDOR PAYMENTS TRACKER ──
model OpsVendorPayment {
  id                 String    @id @default(cuid())
  tenantId           String    @default("default")
  tripId             String
  departureDate      DateTime  @db.Date
  vendorName         String
  category           String // Hotels, Transport, Activities, Meals, Guides, Local vendors, Other
  serviceDescription String?   @db.Text
  agreedAmount       Float     @default(0)
  advancePaid        Float     @default(0)
  remainingPayable   Float     @default(0)
  paymentDate        DateTime?
  paymentMode        String?
  transactionId      String?
  invoiceProof       String?
  status             String    @default("Not Paid") // Not Paid, Advance Paid, Partially Paid, Pending Approval, Paid, Rejected
  paidBy             String?
  remarks            String?   @db.Text
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Restrict)

  @@index([tenantId])
  @@index([tripId, departureDate])
}

// ── NEW: CLIENT RECEIPTS/PAYMENTS TRACKER ──
model OpsClientPayment {
  id            String    @id @default(cuid())
  tenantId      String    @default("default")
  bookingId     String
  amount        Float     @default(0)
  paymentMode   String?
  transactionId String?
  paymentDate   DateTime?
  proofUrl      String?
  status        String    @default("Pending Verification") // Unpaid, Partially Paid, Paid, Pending Verification, Verified, Rejected, Refunded
  collectedBy   String?
  remarks       String?   @db.Text
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  booking Booking @relation(fields: [bookingId], references: [bookingId], onDelete: Cascade)

  @@index([tenantId])
  @@index([bookingId])
}

// ── DEPARTURE-WISE DOCUMENTS ──
model OpsDocument {
  id                 String   @id @default(cuid())
  tenantId           String   @default("default")
  tripId             String
  departureDate      DateTime @db.Date
  category           String // PASSENGER, PAYMENT_PROOF, HOTEL_VOUCHER, VEHICLE, GUIDE_ID, OPERATIONAL
  uploadedById       String
  originalFileName   String
  fileUrl            String
  fileSize           Int
  verificationStatus String   @default("Pending") // Pending, Verified, Rejected, Action Required
  remarks            String?  @db.Text
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  trip       Trip  @relation(fields: [tripId], references: [id], onDelete: Restrict)
  uploadedBy Admin @relation("OpsDocUploadedByAdmin", fields: [uploadedById], references: [id], onDelete: Restrict)

  @@index([tenantId])
  @@index([tripId, departureDate])
}

// ── DEPARTURE-WISE CHATS/MESSAGES ──
model OpsMessage {
  id            String   @id @default(cuid())
  tenantId      String   @default("default")
  tripId        String
  departureDate DateTime @db.Date
  senderType    String // STAFF, GUIDE, PASSENGER
  senderId      String // Admin.id or Passenger Booking ID
  senderName    String
  messageType   String // ANNOUNCEMENT, GROUP, DIRECT
  content       String   @db.Text
  attachments   Json? // Array of attachment URLs
  recipients    Json? // Array of recipient roles/ids
  readBy        Json? // Array of user/admin ids who read
  createdAt     DateTime @default(now())

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Restrict)

  @@index([tenantId])
  @@index([tripId, departureDate])
}

// ── ALLOCATION AUDIT LOG ──
model OpsAllocationAudit {
  id            String   @id @default(cuid())
  tenantId      String   @default("default")
  tripId        String
  departureDate DateTime @db.Date
  action        String   // MANUAL_SAVE | AUTO_CONFIRM | CLEAR | CANCEL_PASSENGER
  actorId       String?  // Admin.id who triggered the action
  actorName     String?  // snapshot of admin name at time of action
  roomCount     Int      @default(0)
  vehicleCount  Int      @default(0)
  cleared       Boolean  @default(false)
  metadata      Json?    // full payload snapshot for traceability
  createdAt     DateTime @default(now())

  @@index([tenantId])
  @@index([tripId, departureDate])
}

// ── VENDORS & RATES DIRECTORY ──

enum OpsSharingType {
  SINGLE
  DOUBLE
  TRIPLE
  QUAD
  FAMILY
}

enum OpsRateBasis {
  PER_PERSON
  PER_ROOM
}

enum OpsMealPlan {
  EP
  CP
  MAP
  AP
}

enum OpsSeasonType {
  STANDARD
  SEASON
  OFF_SEASON
}

enum OpsAddonRateBasis {
  PER_PERSON
  PER_MEAL
  PER_ROOM
  PER_DAY
  PER_VEHICLE
  PER_TENT
  FIXED
}

enum OpsAllocationStatus {
  PLANNED
  CONTACTED
  CONFIRMED
  CANCELLED
}


model OpsAccommodationRate {
  id               String         @id @default(cuid())
  vendorId         String
  propertyName     String?
  city             String?
  roomCategory     String?
  sharingType      OpsSharingType
  rateBasis        OpsRateBasis
  amount           Decimal        @db.Decimal(10, 2)
  mealPlan         OpsMealPlan    @default(EP)
  seasonType       OpsSeasonType  @default(STANDARD)
  validFrom        DateTime?      @db.Date
  validTo          DateTime?      @db.Date
  minimumOccupancy Int            @default(1)
  maximumOccupancy Int            @default(4)
  totalRooms       Int            @default(0)
  notes            String?        @db.Text
  active           Boolean        @default(true)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  vendor      OpsVendor                      @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  allocations OpsDepartureVendorAllocation[]

  @@index([vendorId])
  @@index([city])
  @@index([sharingType])
}

model OpsTransportRate {
  id                   String                         @id @default(cuid())
  vendorId             String
  tripCode             String?
  routeName            String?
  pickupLocation       String?
  dropLocation         String?
  numberOfDays         Int                            @default(1)
  seasonType           String?
  vehicleType          String
  advertisedCapacity   Int                            @default(17)
  sellableSeats        Int                            @default(17)
  totalVehicleCost     Decimal                        @db.Decimal(10, 2)
  driverAllowance      Decimal                        @default(0) @db.Decimal(10, 2)
  tollParkingIncluded  Boolean                        @default(false)
  extraPickupCharge    Decimal                        @default(0) @db.Decimal(10, 2)
  validFrom            DateTime?                      @db.Date
  validTo              DateTime?                      @db.Date
  notes                String?                        @db.Text
  active               Boolean                        @default(true)
  createdAt            DateTime                       @default(now())
  updatedAt            DateTime                       @updatedAt

  vendor      OpsVendor                      @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  allocations OpsDepartureVendorAllocation[]

  @@index([vendorId])
  @@index([tripCode])
}

model OpsVendorAdditionalCharge {
  id             String            @id @default(cuid())
  vendorId       String
  tripCode       String?
  chargeName     String
  chargeCategory String?
  rateBasis      OpsAddonRateBasis
  amount         Decimal           @db.Decimal(10, 2)
  unit           String?
  city           String?
  conditions     String?           @db.Text
  active         Boolean           @default(true)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  vendor OpsVendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@index([vendorId])
}

model OpsDepartureVendorAllocation {
  id                  String              @id @default(cuid())
  departureId         String // represents tripId + departureDate (stable identity string e.g. "tripId_date")
  itineraryDayId      String? // references DayItinerary.id if needed
  vendorId            String
  accommodationRateId String?
  transportRateId     String?
  masterRate          Decimal?            @db.Decimal(10, 2)
  negotiatedRate      Decimal?            @db.Decimal(10, 2)
  finalBookedRate     Decimal?            @db.Decimal(10, 2)
  quantity            Int                 @default(1)
  numberOfRooms       Int                 @default(0)
  numberOfGuests      Int                 @default(0)
  status              OpsAllocationStatus @default(PLANNED)
  confirmationNumber  String?
  confirmedAt         DateTime?
  notes               String?             @db.Text
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  vendor            OpsVendor             @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  accommodationRate OpsAccommodationRate? @relation(fields: [accommodationRateId], references: [id], onDelete: SetNull)
  transportRate     OpsTransportRate?     @relation(fields: [transportRateId], references: [id], onDelete: SetNull)
  tripVendorRateId  String?
  tripVendorRate    OpsTripVendorRate?    @relation(fields: [tripVendorRateId], references: [id], onDelete: SetNull)

  @@index([departureId])
  @@index([vendorId])
}

model OpsTripVendor {
  id        String   @id @default(cuid())
  tripId    String
  vendorId  String
  category  String?  // HOTEL, TRANSPORT, GUIDE, FOOD, OTHER
  preferred Boolean  @default(false)
  priority  Int      @default(0)
  active    Boolean  @default(true)
  notes     String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  trip   Trip      @relation(fields: [tripId], references: [id], onDelete: Cascade)
  vendor OpsVendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  rates  OpsTripVendorRate[]

  @@unique([tripId, vendorId, category])
  @@index([tripId])
  @@index([vendorId])
}

model OpsTripVendorRate {
  id               String   @id @default(cuid())
  tripVendorId     String
  city             String?
  rateType         String   // HOTEL, TRANSPORT, GUIDE, FOOD, OTHER
  roomType         String?
  sharingType      String?  // SINGLE, DOUBLE, TRIPLE, QUAD, FAMILY
  vehicleType      String?
  routeName        String?
  rateBasis        String?  // PER_PERSON, PER_ROOM, PER_VEHICLE, PER_DAY, PER_MEAL, PER_TENT, FIXED
  amount           Decimal  @db.Decimal(10, 2)
  seasonType       String   @default("STANDARD") // STANDARD, SEASON, OFF_SEASON
  validFrom        DateTime? @db.Date
  validTo          DateTime? @db.Date
  minimumOccupancy Int      @default(1)
  maximumOccupancy Int      @default(4)
  sellableSeats    Int      @default(17)
  numberOfDays     Int      @default(1)
  active           Boolean  @default(true)
  notes            String?  @db.Text
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  tripVendor       OpsTripVendor @relation(fields: [tripVendorId], references: [id], onDelete: Cascade)
  allocations      OpsDepartureVendorAllocation[]

  @@index([tripVendorId])
}

// ── VENDOR DIRECTORY & AUTO-PRICING MODELS ──

model DirectoryVendor {
  id              String   @id @default(cuid())
  vendorCode      String   @unique
  name            String
  legalName       String?
  type            DirectoryVendorType

  contactPerson   String?
  contactNumber   String?
  alternateNumber String?
  whatsappNumber  String?
  email           String?

  gstin           String?
  panNumber       String?

  state           String?
  city            String?
  area            String?
  address         String?  @db.Text

  paymentTerms    String?  @db.Text
  creditDays      Int?
  bankDetails     Json?

  rating          Decimal? @db.Decimal(3, 2)
  isActive        Boolean  @default(true)
  notes           String?  @db.Text

  roomRates       DirectoryVendorRoomRate[]
  transportRates  DirectoryVendorTransportRate[]
  foodRates       DirectoryVendorFoodRate[]
  guideRates      DirectoryVendorGuideRate[]
  miscCharges     DirectoryVendorMiscCharge[]
  tripMappings    DirectoryTripVendorMapping[]
  payments        DirectoryVendorPayment[]
  contacts        DirectoryVendorContact[]
  contracts       DirectoryVendorContract[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([type, isActive])
  @@index([state, city])
}

model DirectoryVendorContact {
  id              String   @id @default(cuid())
  vendorId        String
  vendor          DirectoryVendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  contactName     String
  designation     String?
  phone           String
  email           String?
  isPrimary       Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([vendorId])
}

model DirectoryVendorRoomRate {
  id                 String                  @id @default(cuid())
  vendorId           String
  vendor             DirectoryVendor         @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  propertyName       String?
  roomCategory       String                  @default("Standard")
  sharingType        DirectoryRoomSharingType
  standardOccupancy  Int                     @default(2)
  maximumOccupancy   Int                     @default(3)
  mixedOccupancyAllowed Boolean              @default(true)
  rateBasis          DirectoryAccommodationRateBasis  @default(PER_ROOM_PER_NIGHT)

  amount             Decimal                 @db.Decimal(12, 2)
  extraAdultRate     Decimal?                @db.Decimal(12, 2)
  extraChildRate     Decimal?                @db.Decimal(12, 2)
  guideRoomRate      Decimal?                @db.Decimal(12, 2)

  availableRooms     Int?
  mealPlan           DirectoryMealPlan       @default(EP)
  season             DirectoryVendorSeason   @default(ALL)

  validFrom          DateTime?
  validTo            DateTime?

  taxIncluded        Boolean                 @default(false)
  taxPercent         Decimal?                @db.Decimal(5, 2)

  minimumRooms       Int?
  cancellationPolicy String?                 @db.Text
  blackoutDates      Json?

  status             DirectoryVendorRateStatus @default(ACTIVE)

  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt

  @@index([vendorId, sharingType])
  @@index([validFrom, validTo])
}

model DirectoryVendorTransportRate {
  id                    String             @id @default(cuid())
  vendorId              String
  vendor                DirectoryVendor    @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  routeName             String
  pickupLocation        String?
  dropLocation          String?

  vehicleType           String
  seatCapacity          Int
  rateBasis             DirectoryTransportRateBasis

  amount                Decimal            @db.Decimal(12, 2)
  extraCharge           Decimal?           @db.Decimal(12, 2)
  extraKmRate           Decimal?           @db.Decimal(12, 2)
  extraHourRate         Decimal?           @db.Decimal(12, 2)
  nightHaltRate         Decimal?           @db.Decimal(12, 2)

  tollIncluded          Boolean            @default(false)
  parkingIncluded       Boolean            @default(false)
  fuelIncluded          Boolean            @default(true)
  driverAllowanceIncluded Boolean          @default(false)
  stateTaxIncluded      Boolean            @default(false)
  backupVehicleAvailable Boolean           @default(true)

  season                DirectoryVendorSeason @default(ALL)
  validFrom             DateTime?
  validTo               DateTime?

  cancellationPolicy    String?            @db.Text
  status                DirectoryVendorRateStatus @default(ACTIVE)

  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

  @@index([vendorId, vehicleType])
  @@index([validFrom, validTo])
}

model DirectoryVendorFoodRate {
  id              String           @id @default(cuid())
  vendorId        String
  vendor          DirectoryVendor  @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  mealType        String
  menuDescription String?          @db.Text
  isVeg           Boolean          @default(true)
  ratePerPerson   Decimal          @db.Decimal(12, 2)

  minimumPax      Int?
  maximumPax      Int?
  packedMeal      Boolean          @default(false)
  guideMealRate   Decimal?         @db.Decimal(12, 2)
  driverMealRate  Decimal?         @db.Decimal(12, 2)
  taxIncluded     Boolean          @default(false)
  taxPercent      Decimal?         @db.Decimal(5, 2)

  validFrom       DateTime?
  validTo         DateTime?
  cancellationPolicy String?       @db.Text
  status          DirectoryVendorRateStatus @default(ACTIVE)

  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model DirectoryVendorGuideRate {
  id              String           @id @default(cuid())
  vendorId        String
  vendor          DirectoryVendor  @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  serviceName     String
  serviceLocation String?
  languages       String?
  specialization  String?

  dailyRate       Decimal          @db.Decimal(12, 2)
  travelCharge    Decimal?         @db.Decimal(12, 2)
  foodCharge      Decimal?         @db.Decimal(12, 2)
  stayCharge      Decimal?         @db.Decimal(12, 2)

  maximumGroupSize Int?
  emergencySupport Boolean         @default(false)
  idVerified      Boolean          @default(false)
  policeVerified  Boolean          @default(false)
  validFrom       DateTime?
  validTo         DateTime?
  status          DirectoryVendorRateStatus @default(ACTIVE)

  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model DirectoryVendorMiscCharge {
  id          String           @id @default(cuid())
  vendorId    String?
  vendor      DirectoryVendor? @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  chargeName  String
  chargeType  String
  amount      Decimal          @db.Decimal(12, 2)
  unit        DirectoryMiscChargeUnit

  validFrom   DateTime?
  validTo     DateTime?
  notes       String?          @db.Text
  status      DirectoryVendorRateStatus @default(ACTIVE)

  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
