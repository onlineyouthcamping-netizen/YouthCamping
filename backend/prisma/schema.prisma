  subject            String
  body               String   @db.Text
  category           String // e.g. "Booking", "Inquiry", "Ticketing", "General"
  isActive           Boolean  @default(true)
  defaultAttachments Json? // Array of files
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([category])
}

model EmailLog {
